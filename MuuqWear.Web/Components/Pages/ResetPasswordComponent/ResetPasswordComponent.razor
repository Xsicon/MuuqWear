@page "/auth/reset-password"
@layout Layout.AuthLayoutComponent.AuthLayoutComponent
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IAuthService IAuthService
@inject NavigationManager NavigationManager
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Model.Authentication

<PageTitle>Reset Password</PageTitle>

<section class="mw-auth">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-6 col-lg-4 mt-5">
                <div class="mw-auth-card text-center">
                    <a href="/">
                        <img src="/images/muuqwearlogo.png" class="mw-auth-logo mb-3" />
                    </a>
                    <h2 class="mw-auth-title">Reset Password</h2>
                    <p class="mw-auth-subtitle mb-4">
                        Enter your new password below
                    </p>

                    @if (isLoading)
                    {
                        <p class="text-muted">Verifying reset link...</p>
                    }
                    else if (!string.IsNullOrEmpty(tokenError))
                    {
                        <!-- INVALID TOKEN STATE -->
                        <div class="mw-alert-error p-3 rounded mb-3">
                            <span>@tokenError</span>
                        </div>
                        <a href="/forgot-password" class="mw-btn-primary w-100">
                            Request New Reset Link
                        </a>
                    }
                    else if (resetSuccess)
                    {
                        <!-- SUCCESS STATE -->
                        <div class="mw-reset-success">
                            <div class="mw-reset-success__icon">✓</div>
                            <h6 class="mt-3 fw-bold">Password Reset!</h6>
                            <p class="mw-auth-subtitle">
                                Your password has been updated successfully.
                            </p>
                            <a href="/login" class="mw-btn-primary w-100 mt-3">
                                Sign In
                            </a>
                        </div>
                    }
                    else
                    {
                        <!-- RESET FORM -->
                        <div class="mb-3 text-start">
                            <label class="mw-label">New Password</label>
                            <input type="password"
                                   class="form-control mw-input"
                                   placeholder="Enter new password"
                                   value="@newPassword"
                                   @oninput="HandlePasswordInput" />

                            @* strength meter *@
                            @if (!string.IsNullOrEmpty(newPassword))
                            {
                                <div class="mw-strength-meter mt-2">
                                    <div class="mw-strength-bar">
                                        <div class="mw-strength-segment @(StrengthLevel >= 1 ? "active" : "")"
                                             style="@(StrengthLevel >= 1 ? $"background:{StrengthColor}" : "")">
                                        </div>
                                        <div class="mw-strength-segment @(StrengthLevel >= 2 ? "active" : "")"
                                             style="@(StrengthLevel >= 2 ? $"background:{StrengthColor}" : "")">
                                        </div>
                                        <div class="mw-strength-segment @(StrengthLevel >= 3 ? "active" : "")"
                                             style="@(StrengthLevel >= 3 ? $"background:{StrengthColor}" : "")">
                                        </div>
                                        <div class="mw-strength-segment @(StrengthLevel >= 4 ? "active" : "")"
                                             style="@(StrengthLevel >= 4 ? $"background:{StrengthColor}" : "")">
                                        </div>
                                    </div>
                                    <span class="mw-strength-label"
                                          style="color: @StrengthColor">
                                        @StrengthText
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="mb-4 text-start">
                            <label class="mw-label">Confirm Password</label>
                            <input type="password"
                                   class="form-control mw-input"
                                   placeholder="Confirm new password"
                                   @bind="confirmPassword"
                                   @bind:event="oninput" />

                            @* passwords match indicator *@
                            @if (!string.IsNullOrEmpty(confirmPassword))
                            {
                                @if (newPassword == confirmPassword)
                                {
                                    <small class="text-success">✓ Passwords match</small>
                                }
                                else
                                {
                                    <small class="text-danger">✕ Passwords do not match</small>
                                }
                            }
                        </div>

                        <button type="button"
                                class="mw-btn-primary w-100"
                                @onclick="HandleResetPassword"
                                disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="mw-btn-spinner"></span>
                                <span>Updating...</span>
                            }
                            else
                            {
                                <span>Reset Password</span>
                            }
                        </button>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="mt-3 p-3 rounded mw-alert-error">
                                <span>@errorMessage</span>
                            </div>
                        }
                    }

                </div>
            </div>
        </div>
    </div>
</section>

@code {

    // tokens from URL fragment
    private string accessToken = string.Empty;
    private string refreshToken = string.Empty;

    // form state
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private bool isSubmitting = false;
    private bool isLoading = true;
    private bool resetSuccess = false;
    private string errorMessage = string.Empty;
    private string tokenError = string.Empty;

    // password strength
    private int StrengthLevel = 0;
    private string StrengthColor = "";
    private string StrengthText = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // read URL fragment
            var fragment = await JS.InvokeAsync<string>(
                "eval", "window.location.hash");
            if (string.IsNullOrEmpty(fragment))
            {
                tokenError = "Invalid reset link. Please request a new one.";
                isLoading = false;
                StateHasChanged();
                return;
            }

            // parse fragment
            var parameters = fragment
                .TrimStart('#')
                .Split('&')
                .Select(p => p.Split('='))
                .Where(p => p.Length == 2)
                .ToDictionary(
                    p => p[0],
                    p => Uri.UnescapeDataString(p[1]));

            // check type is recovery
            if (!parameters.TryGetValue("type", out var type)
                || type != "recovery")
            {
                tokenError = "Invalid reset link type.";
                isLoading = false;
                StateHasChanged();
                return;
            }

            // get access token
            if (!parameters.TryGetValue("access_token", out var token)
                || string.IsNullOrEmpty(token))
            {
                tokenError = "Invalid reset link. Token missing.";
                isLoading = false;
                StateHasChanged();
                return;
            }

            accessToken = token;
            parameters.TryGetValue("refresh_token", out var rToken);
            refreshToken = rToken ?? "";

            // token valid → show form
            isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            tokenError = "Something went wrong. Please request a new reset link.";
            isLoading = false;
            StateHasChanged();
            Console.WriteLine(ex.Message);
        }
    }

    private void HandlePasswordInput(ChangeEventArgs e)
    {
        newPassword = e.Value?.ToString() ?? "";
        CalculateStrength(newPassword);
    }

    private void CalculateStrength(string password)
    {
        if (string.IsNullOrEmpty(password))
        {
            StrengthLevel = 0;
            StrengthColor = "";
            StrengthText = "";
            return;
        }

        bool hasMinLength = password.Length >= 8;
        bool hasLetter = password.Any(char.IsLetter);
        bool hasDigit = password.Any(char.IsDigit);
        bool hasSpecial = password.Any(c => !char.IsLetterOrDigit(c));

        if (password.Length < 6)
        {
            StrengthLevel = 1;
            StrengthColor = "#ef4444";
            StrengthText = "Weak";
        }
        else if (!hasMinLength || (hasLetter && !hasDigit) || (!hasLetter && hasDigit))
        {
            StrengthLevel = 2;
            StrengthColor = "#f97316";
            StrengthText = "Fair";
        }
        else if (hasMinLength && hasLetter && hasDigit && !hasSpecial)
        {
            StrengthLevel = 3;
            StrengthColor = "#eab308";
            StrengthText = "Good";
        }
        else if (hasMinLength && hasLetter && hasDigit && hasSpecial)
        {
            StrengthLevel = 4;
            StrengthColor = "#22c55e";
            StrengthText = "Strong";
        }
    }

    private async Task HandleResetPassword()
    {
        errorMessage = string.Empty;

        // validate
        if (string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Please enter a new password";
            return;
        }

        if (newPassword.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        var result = await IAuthService.UpdatePassword(
            new ResetPasswordModel
            {
                AccessToken = accessToken,
                RefreshToken = refreshToken,
                NewPassword = newPassword,
                ConfirmPassword = confirmPassword
            });

        if (result.Success)
        {
            // show success state
            resetSuccess = true;
        }
        else
        {
            errorMessage = result.Message;
        }

        isSubmitting = false;
        StateHasChanged();
    }
}