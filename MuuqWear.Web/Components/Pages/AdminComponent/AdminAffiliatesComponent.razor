@page "/admin/affiliates"
@layout Layout.AdminLayoutComponent.AdminDashboardLayoutComponent
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using MuuqWear.Application.Services.AffiliateService
@inject IAffiliateService AffiliateService
@attribute [Authorize(Roles = "admin")]

<div class="mw-affiliates">
    <!-- HEADER -->
    <div class="mw-affiliates__header">
        <h1 class="mw-affiliates__title">Affiliate Management</h1>
    </div>

    @if (isLoading)
    {
        <p>Loading applications...</p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="error">@errorMessage</p>
    }
    else
    {
        <!-- TABS -->
        <div class="mw-affiliates__tabs">
            <button class="mw-tab @(activeTab == "pending" ? "active" : "")"
                    @onclick='() => activeTab = "pending"'>
                PENDING (@pendingApplications.Count)
            </button>
            <button class="mw-tab @(activeTab == "active" ? "active" : "")"
                    @onclick='() => activeTab = "active"'>
                ACTIVE (@activeApplications.Count/@totalActiveDays d)
            </button>
            <button class="mw-tab @(activeTab == "waitlist" ? "active" : "")"
                    @onclick='() => activeTab = "waitlist"'>
                WAITLIST (@waitListApplications.Count)
            </button>
        </div>

        <!-- AFFILIATE LIST -->
        <div class="mw-affiliates__list">
            @if (activeTab == "pending")
            {
                @if (!pendingApplications.Any())
                {
                    <p>No pending applications</p>
                }
                else
                {
                    @foreach (var application in pendingApplications)
                    {
                        <AffiliateRowComponent Application="@application"
                                      OnAction="HandleAction" />
                    }
                }
            }
            else if (activeTab == "active")
            {
                @if (!activeApplications.Any())
                {
                    <p>No active affiliates</p>
                }
                else
                {
                    @foreach (var application in activeApplications)
                    {
                        <AffiliateRow Application="@application"
                                      OnAction="HandleAction"
                                      ShowActiveActions="true" />
                    }
                }
            }
            else if (activeTab == "waitlist")
            {
                @if (!waitListApplications.Any())
                {
                    <p>No waitlisted applications</p>
                }
                else
                {
                    @foreach (var application in waitListApplications)
                    {
                        <AffiliateRow Application="@application"
                                      OnAction="HandleAction" />
                    }
                }
            }
        </div>
    }
</div>

<!-- ? VIEW MODAL -->
@if (showViewModal && selectedApplication != null)
{
    <div class="modal-overlay" @onclick="CloseViewModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>Application Details</h2>
                <button class="modal-close" @onclick="CloseViewModal">?</button>
            </div>

            <div class="modal-body">
                <!-- Personal Info -->
                <div class="modal-section">
                    <h3>Personal Information</h3>
                    <p><strong>Name:</strong> @selectedApplication.FullName</p>
                    <p><strong>Email:</strong> @selectedApplication.Email</p>
                    <p><strong>Status:</strong> <span class="status-badge status-@selectedApplication.Status">@selectedApplication.Status</span></p>
                    <p><strong>Applied:</strong> @selectedApplication.FormattedDate</p>
                </div>

                <!-- Social Handles -->
                <div class="modal-section">
                    <h3>Social Media</h3>
                    @if (selectedApplication.SocialHandles != null && selectedApplication.SocialHandles.Any())
                    {
                        @foreach (var social in selectedApplication.SocialHandles)
                        {
                            <p><strong>@social.Platform:</strong> @@social.Handle</p>
                        }
                    }
                    else
                    {
                        <p>No social handles provided</p>
                    }
                    <p><strong>Total Audience:</strong> @selectedApplication.AudienceSize.ToString("N0") followers</p>
                </div>

                <!-- Content Info -->
                <div class="modal-section">
                    <h3>Content Information</h3>
                    <p><strong>Niche:</strong> @selectedApplication.ContentNiche</p>
                    @if (!string.IsNullOrEmpty(selectedApplication.PortfolioUrl))
                    {
                        <p><strong>Portfolio:</strong> <a href="@selectedApplication.PortfolioUrl" target="_blank">@selectedApplication.PortfolioUrl</a></p>
                    }
                </div>

                <!-- Why Muuqwear -->
                @if (!string.IsNullOrEmpty(selectedApplication.WhyMuuqwear))
                {
                    <div class="modal-section">
                        <h3>Why Muuqwear?</h3>
                        <p>@selectedApplication.WhyMuuqwear</p>
                    </div>
                }

                <!-- Admin Notes -->
                @if (!string.IsNullOrEmpty(selectedApplication.AdminNotes))
                {
                    <div class="modal-section">
                        <h3>Admin Notes</h3>
                        <p>@selectedApplication.AdminNotes</p>
                    </div>
                }
            </div>
        </div>
    </div>
}