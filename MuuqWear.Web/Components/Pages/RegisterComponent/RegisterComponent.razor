@page "/register"
@layout Components.Layout.AuthLayoutComponent.AuthLayoutComponent
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using MuuqWear.Model
@using MuuqWear.Application.Services.AuthService;
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IAuthService IAuthService;
@inject NavigationManager NavigationManager;
@inject AuthStateService AuthStateService


<PageTitle>Register</PageTitle>

<section class="mw-auth">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-12 col-md-8 col-lg-5">

                <div class="mw-auth-card">

                    <!-- LOGO -->
                    <div class="text-center mb-4">
                        <a href="/">
                        <img src="/images/muuqwearlogo.png" class="mw-auth-logo mb-3" />
                        </a>
                        <h2 class="mw-auth-title mt-3">Create Account</h2>
                        <p class="mw-auth-subtitle">
                            Join MuuqWear and explore premium essentials
                        </p>
                    </div>

                    <!-- FORM -->
                    <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">

                        <DataAnnotationsValidator />

                        <!-- NAME -->
                        <div class="mb-3">
                            <label class="mw-label">Full Name</label>
                            <InputText class="form-control mw-input"
                                       @bind-Value="registerModel.FullName" />
                            <ValidationMessage For="@(() => registerModel.FullName)" />
                        </div>

                        <!-- EMAIL -->
                        <div class="mb-3">
                            <label class="mw-label">Email</label>
                            <InputText class="form-control mw-input"
                                       @bind-Value="registerModel.Email" />
                            <ValidationMessage For="@(() => registerModel.Email)" />
                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-3">
                            <label class="mw-label">Password</label>
                            <InputText type="password"
                                       class="form-control mw-input"
                                       Value="@registerModel.Password"
                                       ValueChanged="HandlePasswordInput"
                                       ValueExpression="@(() => registerModel.Password)" />
                            <ValidationMessage For="@(() => registerModel.Password)" />

                            @* show meter only when user starts typing *@
                            @if (!string.IsNullOrEmpty(registerModel.Password))
                            {
                                <div class="mw-strength-bar">
                                    <div class="mw-strength-segment @(StrengthLevel >= 1 ? "active" : "")"
                                         style="@(StrengthLevel >= 1 ? $"background:{StrengthColor}" : "")">
                                    </div>
                                    <div class="mw-strength-segment @(StrengthLevel >= 2 ? "active" : "")"
                                         style="@(StrengthLevel >= 2 ? $"background:{StrengthColor}" : "")">
                                    </div>
                                    <div class="mw-strength-segment @(StrengthLevel >= 3 ? "active" : "")"
                                         style="@(StrengthLevel >= 3 ? $"background:{StrengthColor}" : "")">
                                    </div>
                                    <div class="mw-strength-segment @(StrengthLevel >= 4 ? "active" : "")"
                                         style="@(StrengthLevel >= 4 ? $"background:{StrengthColor}" : "")">
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- CONFIRM PASSWORD -->
                        <div class="mb-4">
                            <label class="mw-label">Confirm Password</label>
                            <InputText type="password"
                                       class="form-control mw-input"
                                       @bind-Value="registerModel.ConfirmPassword" />
                            <ValidationMessage For="@(() => registerModel.ConfirmPassword)" />
                        </div>

                        <!-- SUBMIT -->
                        <button type="submit" class="mw-btn-primary w-100">
                            Create Account
                        </button>
                        <div class="@messageCssClass">
                            <span>@message</span>
                        </div>

                    </EditForm>

                    <!-- LOGIN LINK -->
                    <p class="text-center mt-4 small">
                        Already have an account?
                        <a href="/login" class="mw-link">Sign in</a>
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

