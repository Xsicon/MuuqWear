@page "/admin/products"
@layout Layout.AdminLayout.AdminDashboardLayout
@rendermode InteractiveServer
@using MuuqWear.Application.Services.ProductService
@using MuuqWear.Application.Services.CategoryService
@using MuuqWear.Model.Products
@using Microsoft.AspNetCore.Authorization
@using MuuqWear.Web.Components.Shared
@inject IProductService ProductService
@inject ICategoryService CategoryService
@attribute [Authorize(Roles = "admin")]

@if (!isFormOpen)
{
    <!-- PRODUCTS LIST VIEW -->
    <section class="mw-admin-products">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
            <h3 class="mw-admin-heading">Products</h3>
            <button class="mw-btn-primary" @onclick="OpenAddForm">+ Add Product</button>
        </div>

        <div class="mw-admin-card mb-3">
            <input class="mw-admin-input w-100"
                   placeholder="Search products..."
                   value="@searchQuery"
                   @oninput="HandleSearchInput"
                   @onkeydown="HandleSearchKeyDown" />
        </div>

        <div class="mw-admin-card">
            <div class="table-responsive">
                <table class="table mw-admin-table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Badge</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="7" class="text-center">Loading...</td>
                            </tr>
                        }
                        else if (!FilteredProducts.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center">No products found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in FilteredProducts)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl" class="mw-product-thumb" />
                                            }
                                            <span>@item.Name</span>
                                        </div>
                                    </td>
                                    <td>@(Categories.FirstOrDefault(c => c.Id == item.CategoryId)?.Name ?? "-")</td>
                                    <td>@item.Price.ToString("C")</td>
                                    <td>
                                        <span class="mw-stock @(item.Stock > 0 ? "in" : "out")">
                                            @(item.Stock > 0 ? "In Stock" : "Out")
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Badge))
                                        {
                                            <span class="mw-badge">@item.Badge</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="mw-stock @(item.IsActive ? "in" : "out")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="mw-action-btn" @onclick="() => OpenEditForm(item)">Edit</button>
                                        <button class="mw-action-btn text-danger" @onclick="() => OpenDeleteModal(item)">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @* ✅ add pagination below table *@
        <PaginationComponent TItem="ProductModel"
                             TotalCount="_totalCount"
                             CurrentPage="_currentPage"
                             PageSize="_pageSize"
                             OnPageChanged="HandlePageChanged" />
        <!-- DELETE MODAL -->
        @if (isDeleteModalOpen)
        {
            <div class="mw-modal-overlay" @onclick="CloseDeleteModal">
                <div class="mw-modal" style="max-width:400px;" @onclick:stopPropagation="true">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5>Delete Product</h5>
                        <button class="mw-close-btn" @onclick="CloseDeleteModal">✕</button>
                    </div>
                    <p>Are you sure you want to delete <strong>@deletingProductName</strong>?</p>
                    <p class="text-danger small">This action cannot be undone.</p>
                    <div class="d-flex gap-2 mt-3">
                        <button class="mw-btn-secondary w-100" @onclick="CloseDeleteModal">Cancel</button>
                        <button class="mw-btn-danger w-100" @onclick="ConfirmDelete" disabled="@isDeleting">
                            @(isDeleting ? "Deleting..." : "Delete")
                        </button>
                    </div>
                </div>
            </div>
        }

    </section>
}
else
{
    <!-- ADD / EDIT FORM VIEW -->
    <section class="mw-product-form">

        <!-- HEADER -->
        <div class="mw-product-form__header">
            <div class="d-flex align-items-center gap-3">
                <button class="mw-back-btn" @onclick="CloseForm">
                    ← Back
                </button>
                <h3 class="mw-admin-heading mb-0">
                    @(isEditMode ? "Edit Product" : "Add New Product")
                </h3>
            </div>
            <div class="d-flex gap-2">
                <button class="mw-btn-secondary" @onclick="CloseForm">Cancel</button>
                <button class="mw-btn-primary" @onclick="SaveProduct" disabled="@isSaving">
                    @(isSaving ? "Saving..." : (isEditMode ? "Update Product" : "Add Product"))
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }

        <div class="row g-4 mt-1">

            <!-- LEFT COLUMN -->
            <div class="col-12 col-lg-7">

                <!-- GENERAL INFORMATION -->
                <div class="mw-form-card mb-4">
                    <h6 class="mw-form-card__title">General Information</h6>

                    <div class="mb-3">
                        <label class="mw-form-label">Name Product</label>
                        <input class="mw-admin-input w-100"
                               placeholder="e.g. Puffer Jacket"
                               @bind="newProduct.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="mw-form-label">Description Product</label>
                        <textarea class="mw-admin-input w-100"
                                  rows="4"
                                  placeholder="Describe the product..."
                                  @bind="newProduct.Description"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="mw-form-label">Size</label>
                        <p class="mw-form-hint">Pick Available Size</p>
                        <div class="mw-size-selector">
                            @foreach (var size in AvailableSizes)
                            {
                                <button class="mw-size-btn @(SelectedSizes.Contains(size) ? "active" : "")"
                                        @onclick="() => ToggleSize(size)">
                                    @size
                                </button>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="mw-form-label">Gender</label>
                        <p class="mw-form-hint">Pick Available Gender</p>
                        <div class="mw-gender-selector">
                            @foreach (var gender in AvailableGenders)
                            {
                                <label class="mw-gender-option">
                                    <input type="radio"
                                           name="gender"
                                           value="@gender"
                                           checked="@(newProduct.Gender == gender)"
                                           @onchange="() => newProduct.Gender = gender" />
                                    <span>@gender</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <!-- PRICING AND STOCK -->
                <div class="mw-form-card">
                    <h6 class="mw-form-card__title">Pricing And Stock</h6>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="mw-form-label">Base Pricing</label>
                            <div class="mw-input-prefix">
                                <span>$</span>
                                <input type="number"
                                       class="mw-admin-input w-100"
                                       placeholder="0.00"
                                       @bind="newProduct.Price" />
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="mw-form-label">Stock</label>
                            <input type="number"
                                   class="mw-admin-input w-100"
                                   placeholder="0"
                                   @bind="newProduct.Stock" />
                        </div>
                        <div class="col-6">
                            <label class="mw-form-label">Badge</label>
                            <select class="mw-admin-input w-100" @bind="newProduct.Badge">
                                <option value="">None</option>
                                <option value="NEW">NEW</option>
                                <option value="SALE">SALE</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="mw-form-label">Status</label>
                            <select class="mw-admin-input w-100" @bind="newProduct.IsActive">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="mw-form-label">Sections</label>
                        <div class="d-flex gap-4 mt-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       id="isNewArrival"
                                       @bind="newProduct.IsNewArrival" />
                                <label class="form-check-label" for="isNewArrival">New Arrival</label>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       id="isFeatured"
                                       @bind="newProduct.IsFeatured" />
                                <label class="form-check-label" for="isFeatured">Featured</label>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       id="isBestSeller"
                                       @bind="newProduct.IsBestSeller" />
                                <label class="form-check-label" for="isBestSeller">Best Seller</label>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="col-12 col-lg-5">



                <!-- IMAGE UPLOAD -->
                <div class="mw-form-card mb-4">
                    <h6 class="mw-form-card__title">Upload Image</h6>

                    <!-- IMAGE PREVIEW -->
                    <div class="mw-image-preview">
                        @if (!string.IsNullOrEmpty(newProduct.ImageUrl))
                        {
                            <img src="@newProduct.ImageUrl" class="mw-image-preview__img" />
                        }
                        else
                        {
                            <div class="mw-image-preview__placeholder">
                                <span>No image selected</span>
                            </div>
                        }
                    </div>

                    <!-- IMAGE SOURCE -->
                    <div class="mt-3">
                        <label class="mw-form-label">Image Source</label>
                        <select class="mw-admin-input w-100 mb-2" @bind="imageSource">
                            <option value="url">Paste URL</option>
                            <option value="upload">Upload File</option>
                        </select>

                        @if (imageSource == "url")
                        {
                            <input class="mw-admin-input w-100"
                                   placeholder="https://images.unsplash.com/..."
                                   @bind="newProduct.ImageUrl" />
                        }
                        else
                        {
                            <InputFile OnChange="HandleImageUpload" class="mw-file-input" />
                            @if (isUploading)
                            {
                                <p class="text-muted mt-1 small">Uploading...</p>
                            }
                        }
                    </div>
                </div>

                <!-- CATEGORY -->
                <div class="mw-form-card">
                    <h6 class="mw-form-card__title">Category</h6>

                    <div class="mb-3">
                        <label class="mw-form-label">Product Category</label>
                        <select class="mw-admin-input w-100" @bind="newProduct.CategoryId">
                            <option value="">Select Category</option>
                            @foreach (var cat in Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <!-- ADD CATEGORY -->
                    <div class="mw-add-category">
                        <input class="mw-admin-input flex-grow-1"
                               placeholder="New category name..."
                               @bind="newCategoryName" />
                        <button class="mw-btn-primary"
                                @onclick="AddCategory"
                                disabled="@isAddingCategory">
                            @(isAddingCategory ? "Adding..." : "Add Category")
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(categoryError))
                    {
                        <p class="text-danger small mt-1">@categoryError</p>
                    }
                </div>

                <!-- PRODUCT IMAGES -->
                @if (isEditMode && editingProductId != Guid.Empty)
                {
                    <div class="mw-form-card mt-4">
                        <h6 class="mw-form-card__title">Product Images</h6>
                        <p class="mw-form-hint">
                            Add multiple images for product detail page
                        </p>

                        <!-- EXISTING IMAGES -->
                        @if (editingProductImages.Any())
                        {
                            <div class="mw-product-images-grid mb-3">
                                @foreach (var img in editingProductImages.OrderBy(i => i.SortOrder))
                                {
                                    <div class="mw-product-image-item">

                                        <!-- IMAGE PREVIEW -->
                                        <img src="@img.ImageUrl" class="mw-product-image-thumb" />

                                        <!-- SORT ORDER -->
                                        <input type="number"
                                               class="mw-admin-input w-100 mt-1"
                                               placeholder="Order"
                                               value="@img.SortOrder"
                                               @onchange="async e => await UpdateImageOrder(img, e)" />

                                        <!-- DELETE BUTTON -->
                                        <button class="mw-btn-danger w-100 mt-1"
                                                @onclick="() => DeleteImage(img.Id)">
                                            Remove
                                        </button>

                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">No additional images yet.</p>
                        }

                        <!-- ADD NEW IMAGE -->
                        <div class="mb-2">
                            <label class="mw-form-label">Add Image URL</label>
                            <div class="d-flex gap-2">
                                <input class="mw-admin-input flex-grow-1"
                                       placeholder="https://images.unsplash.com/..."
                                       @bind="newImageUrl" />
                                <button class="mw-btn-primary"
                                        @onclick="AddImageUrl"
                                        disabled="@isAddingImage">
                                    @(isAddingImage ? "Adding..." : "Add")
                                </button>
                            </div>
                        </div>

                        <!-- OR UPLOAD FILE -->
                        <div>
                            <label class="mw-form-label">Or Upload Image</label>
                            <InputFile OnChange="HandleAdditionalImageUpload" />
                            @if (isUploadingAdditional)
                            {
                                <p class="text-muted small mt-1">Uploading...</p>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(imageError))
                        {
                            <p class="text-danger small mt-2">@imageError</p>
                        }
                    </div>
                }

            </div>
        </div>
    </section>
}




