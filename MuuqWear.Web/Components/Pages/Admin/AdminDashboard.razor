@page "/admin"
@layout Components.Layout.AdminDashboardLayout

<PageTitle>Admin Dashboard</PageTitle>

<div class="dashboard-content">

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <p class="stat-label">Total Active Users</p>
                <div class="stat-icon users">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </div>
            </div>
            <p class="stat-value">290,000</p>
            <p class="stat-change positive">↑ 8.5% from last month</p>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <p class="stat-label">Total Downloads</p>
                <div class="stat-icon downloads">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" x2="12" y1="15" y2="3" />
                    </svg>
                </div>
            </div>
            <p class="stat-value">290,000+</p>
            <p class="stat-change positive">↑ 12% from last month</p>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <p class="stat-label">Active Products</p>
                <div class="stat-icon products">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                </div>
            </div>
            <p class="stat-value">6</p>
            <p class="stat-change neutral">6 software solutions</p>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <p class="stat-label">Average Growth</p>
                <div class="stat-icon growth">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                        <polyline points="16 7 22 7 22 13" />
                    </svg>
                </div>
            </div>
            <p class="stat-value">+16.3%</p>
            <p class="stat-change positive">↑ Across all products</p>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-row">
        <!-- Bar Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                <span>Active Users by Product</span>
            </div>
            <div class="bar-chart-wrapper">
                <div class="bar-y-axis">
                    <span>120000</span>
                    <span>90000</span>
                    <span>60000</span>
                    <span>30000</span>
                    <span>0</span>
                </div>
                <div class="bar-chart-main">
                    <div class="bar-chart-area">
                        <!-- Grid lines -->
                        <div class="bar-grid-line" style="bottom: 100%"></div>
                        <div class="bar-grid-line" style="bottom: 75%"></div>
                        <div class="bar-grid-line" style="bottom: 50%"></div>
                        <div class="bar-grid-line" style="bottom: 25%"></div>
                        <div class="bar-grid-line" style="bottom: 0%"></div>
                        @foreach (var product in usersChartData)
                        {
                            <div class="bar-item">
                                <div class="bar" style="height: @(product.Height)%"></div>
                            </div>
                        }
                    </div>
                    <div class="bar-x-axis">
                        @foreach (var product in usersChartData)
                        {
                            <span>@product.Name</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Pie Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                </svg>
                <span>Product Categories</span>
            </div>
            <div class="pie-chart-container">
                <div class="pie-chart">
                    <svg viewBox="0 0 100 100">
                        <!-- Data & Analytics - Blue -->
                        <circle cx="50" cy="50" r="40" fill="transparent" stroke="#3b82f6" stroke-width="20" stroke-dasharray="41.89 209.44" stroke-dashoffset="0" transform="rotate(-90 50 50)" />
                        <!-- Communication - Purple -->
                        <circle cx="50" cy="50" r="40" fill="transparent" stroke="#8b5cf6" stroke-width="20" stroke-dasharray="41.89 209.44" stroke-dashoffset="-41.89" transform="rotate(-90 50 50)" />
                        <!-- Project - Green -->
                        <circle cx="50" cy="50" r="40" fill="transparent" stroke="#10b981" stroke-width="20" stroke-dasharray="41.89 209.44" stroke-dashoffset="-83.78" transform="rotate(-90 50 50)" />
                        <!-- Document - Orange -->
                        <circle cx="50" cy="50" r="40" fill="transparent" stroke="#f97316" stroke-width="20" stroke-dasharray="41.89 209.44" stroke-dashoffset="-125.67" transform="rotate(-90 50 50)" />
                        <!-- Collaboration - Indigo -->
                        <circle cx="50" cy="50" r="40" fill="transparent" stroke="#6366f1" stroke-width="20" stroke-dasharray="41.89 209.44" stroke-dashoffset="-167.56" transform="rotate(-90 50 50)" />
                        <!-- Cloud - Cyan -->
                        <circle cx="50" cy="50" r="40" fill="transparent" stroke="#0ea5e9" stroke-width="20" stroke-dasharray="41.89 209.44" stroke-dashoffset="-209.44" transform="rotate(-90 50 50)" />
                    </svg>
                </div>
                <div class="pie-legend">
                    <div class="legend-item"><span class="legend-color" style="background: #10b981"></span>Communication</div>
                    <div class="legend-item"><span class="legend-color" style="background: #3b82f6"></span>Data</div>
                    <div class="legend-item"><span class="legend-color" style="background: #8b5cf6"></span>Project</div>
                    <div class="legend-item"><span class="legend-color" style="background: #0ea5e9"></span>Cloud</div>
                    <div class="legend-item"><span class="legend-color" style="background: #f97316"></span>Document</div>
                    <div class="legend-item"><span class="legend-color" style="background: #6366f1"></span>Collaboration</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Line Chart -->
    <div class="chart-card full-width">
        <div class="chart-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                <polyline points="16 7 22 7 22 13" />
            </svg>
            <span>Total Users Growth (Last 6 Months)</span>
        </div>
        <div class="line-chart-wrapper">
            <div class="line-chart-y-axis">
                <span>300000</span>
                <span>225000</span>
                <span>150000</span>
                <span>75000</span>
                <span>0</span>
            </div>
            <div class="line-chart-main">
                <div class="line-chart-area" @onmouseleave="() => hoveredPointIndex = -1">
                    <svg viewBox="0 0 500 200" preserveAspectRatio="none">
                        <!-- Grid lines -->
                        <line x1="0" y1="40" x2="500" y2="40" stroke="#2a3441" stroke-dasharray="3 3" />
                        <line x1="0" y1="80" x2="500" y2="80" stroke="#2a3441" stroke-dasharray="3 3" />
                        <line x1="0" y1="120" x2="500" y2="120" stroke="#2a3441" stroke-dasharray="3 3" />
                        <line x1="0" y1="160" x2="500" y2="160" stroke="#2a3441" stroke-dasharray="3 3" />
                        <!-- Area fill -->
                        <path d="M0,50 L100,43 L200,37 L300,27 L400,17 L500,7 L500,200 L0,200 Z" fill="rgba(19,127,236,0.08)" />
                        <!-- Line -->
                        <polyline points="0,50 100,43 200,37 300,27 400,17 500,7" fill="none" stroke="#137fec" stroke-width="3" />
                        <!-- Data points and hover areas -->
                        @for (int i = 0; i < lineChartPoints.Count; i++)
                        {
                            var point = lineChartPoints[i];
                            var idx = i;
                            @if (hoveredPointIndex == idx)
                            {
                                <!-- Vertical dashed line -->
                                <line x1="@point.X" y1="0" x2="@point.X" y2="200" stroke="#5a6d7f" stroke-width="1" stroke-dasharray="4 3" />
                                <!-- Outer ring -->
                                <circle cx="@point.X" cy="@point.Y" r="8" fill="#101922" stroke="#137fec" stroke-width="2" />
                            }
                            <circle cx="@point.X" cy="@point.Y" r="5" fill="#137fec" />
                            <!-- Invisible larger hit area -->
                            <circle cx="@point.X" cy="@point.Y" r="20" fill="transparent" @onmouseenter="() => hoveredPointIndex = idx" style="cursor: pointer" />
                        }
                    </svg>
                    @if (hoveredPointIndex >= 0 && hoveredPointIndex < lineChartPoints.Count)
                    {
                        var hp = lineChartPoints[hoveredPointIndex];
                        <div class="chart-tooltip" style="left: @(hp.X / 5.0)%; top: @(hp.Y / 2.0 + 15)%;">
                            <span class="tooltip-label">@hp.Month</span>
                            <span class="tooltip-value">users : @hp.Users.ToString("N0")</span>
                        </div>
                    }
                </div>
                <div class="line-chart-x-axis">
                    <span>Aug</span>
                    <span>Sep</span>
                    <span>Oct</span>
                    <span>Nov</span>
                    <span>Dec</span>
                    <span>Jan</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int hoveredPointIndex = -1;


    private class ChartData
    {
        public string Name { get; set; } = "";
        public int Users { get; set; }
        public int Height { get; set; }
    }
    private List<ChartData> usersChartData = new()
    {
        new ChartData { Name = "DataCore", Users = 52340, Height = 43 },
        new ChartData { Name = "ChatFlow", Users = 38620, Height = 32 },
        new ChartData { Name = "ProjectPulse", Users = 31450, Height = 26 },
        new ChartData { Name = "DocuFlow", Users = 45890, Height = 38 },
        new ChartData { Name = "TeamHub", Users = 18200, Height = 15 },
        new ChartData { Name = "CloudVault", Users = 103500, Height = 86 }
    };

    private List<LineChartPoint> lineChartPoints = new()
    {
        new LineChartPoint { Month = "Aug", Users = 225000, X = 0, Y = 50 },
        new LineChartPoint { Month = "Sep", Users = 236000, X = 100, Y = 43 },
        new LineChartPoint { Month = "Oct", Users = 245000, X = 200, Y = 37 },
        new LineChartPoint { Month = "Nov", Users = 260000, X = 300, Y = 27 },
        new LineChartPoint { Month = "Dec", Users = 275000, X = 400, Y = 17 },
        new LineChartPoint { Month = "Jan", Users = 290000, X = 500, Y = 7 }
    };
    private class LineChartPoint
    {
        public string Month { get; set; } = "";
        public int Users { get; set; }
        public int X { get; set; }
        public int Y { get; set; }
    }
}
