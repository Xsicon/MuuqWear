@page "/admin/affiliates"
@layout Layout.AdminLayout.AdminDashboardLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "admin")]

<div class="mw-affiliates">

    <!-- HEADER -->
    <div class="mw-affiliates__header">
        <h1 class="mw-affiliates__title">Affiliate Management</h1>
    </div>

    <!-- TABS -->
    <div class="mw-affiliates__tabs">
        <button class="mw-tab @(activeTab == "pending" ? "active" : "")"
                @onclick='() => activeTab = "pending"'>
            PENDING (@pendingAffiliates.Count)
        </button>
        <button class="mw-tab @(activeTab == "active" ? "active" : "")"
                @onclick='() => activeTab = "active"'>
            ACTIVE (@activeAffiliates.Count/@totalDays)
        </button>
        <button class="mw-tab @(activeTab == "payouts" ? "active" : "")"
                @onclick='() => activeTab = "payouts"'>
            PAYOUTS (@payoutsAffiliates.Count)
        </button>
    </div>

    <!-- AFFILIATE LIST -->
    <div class="mw-affiliates__list">
        @if (activeTab == "pending")
        {
            @foreach (var affiliate in pendingAffiliates)
            {
                <AffiliateRow Affiliate="@affiliate" OnAction="HandleAction" />
            }
        }
        else if (activeTab == "active")
        {
            @foreach (var affiliate in activeAffiliates)
            {
                <AffiliateRow Affiliate="@affiliate" OnAction="HandleAction" ShowActiveActions="true" />
            }
        }
        else if (activeTab == "payouts")
        {
            @foreach (var affiliate in payoutsAffiliates)
            {
                <AffiliateRow Affiliate="@affiliate" OnAction="HandleAction" ShowPayoutActions="true" />
            }
        }
    </div>

</div>

