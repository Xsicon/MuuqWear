@page "/admin/tickets"
@layout Layout.AdminLayout.AdminDashboardLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using MuuqWear.Application.Interfaces
@using MuuqWear.Application.Services.HelpCenterService
@using MuuqWear.Model.HelpCenter
@inject IHelpCenterService HelpCenterService
@attribute [Authorize(Roles = "admin")]

<PageTitle>Support Tickets</PageTitle>

<div class="at-page">

    <h1 class="at-title">Support Tickets</h1>

    <!-- ─── STATS ─────────────────────────────────────────── -->
    <div class="at-stats">

        <div class="at-stat-card">
            <div class="at-stat-card__icon at-stat-card__icon--yellow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <p class="at-stat-card__number">@(stats?.OpenCount ?? 0)</p>
            <p class="at-stat-card__label">Open Tickets</p>
        </div>

        <div class="at-stat-card">
            <div class="at-stat-card__icon at-stat-card__icon--blue">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
                    <path d="M21 3v5h-5"></path>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
                    <path d="M8 16H3v5"></path>
                </svg>
            </div>
            <p class="at-stat-card__number">@(stats?.InProgressCount ?? 0)</p>
            <p class="at-stat-card__label">In Progress</p>
        </div>

        <div class="at-stat-card">
            <div class="at-stat-card__icon at-stat-card__icon--green">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21.801 10A10 10 0 1 1 17 3.335"></path>
                    <path d="m9 11 3 3L22 4"></path>
                </svg>
            </div>
            <p class="at-stat-card__number">@(stats?.TotalCount ?? 0)</p>
            <p class="at-stat-card__label">Total Tickets</p>
        </div>

    </div>

    <!-- ─── MAIN GRID ─────────────────────────────────────── -->
    <div class="at-grid">

        <!-- ─── LEFT — TICKET LIST ─────────────────────────── -->
        <div class="at-list-col">
            <div class="at-card">

                <div class="at-card__header">
                    <h3 class="at-card__title">Support Tickets</h3>
                    <select class="at-filter-select"
                            @onchange="HandleStatusFilter">
                        <option value="">All</option>
                        <option value="open">Open</option>
                        <option value="in_progress">In Progress</option>
                        <option value="resolved">Resolved</option>
                    </select>
                </div>

                <div class="at-card__body">
                    @if (isLoading)
                    {
                        <p class="at-empty">Loading...</p>
                    }
                    else if (!tickets.Any())
                    {
                        <p class="at-empty">No tickets found.</p>
                    }
                    else
                    {
                        <div class="at-ticket-list">
                            @foreach (var ticket in tickets)
                            {
                                <button class="at-ticket-row @(selectedTicket?.Id == ticket.Id ? "at-ticket-row--active" : "")"
                                        @onclick="() => SelectTicket(ticket)"
                                        @key="ticket.Id">

                                    <div class="at-ticket-row__top">
                                        <div class="at-ticket-row__badges">
                                            <span class="at-ticket-number">
                                                @ticket.TicketNumber
                                            </span>
                                            <span class="at-badge @GetPriorityClass(ticket.Priority)">
                                                @GetPriorityDisplay(ticket.Priority)
                                            </span>
                                        </div>
                                        <span class="at-badge @GetStatusClass(ticket.Status)">
                                            @GetStatusDisplay(ticket.Status)
                                        </span>
                                    </div>

                                    <p class="at-ticket-row__subject">@ticket.Subject</p>
                                    <p class="at-ticket-row__meta">
                                        @ticket.Name · @ticket.Category
                                    </p>
                                    <p class="at-ticket-row__date">
                                        @ticket.CreatedAt?.ToString("dd/MM/yyyy")
                                    </p>

                                </button>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>

        <!-- ─── RIGHT — TICKET DETAIL ──────────────────────── -->
        <div class="at-detail-col">
            @if (selectedTicket == null)
            {
                <div class="at-card at-card--empty">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40"
                         viewBox="0 0 24 24" fill="none" stroke="#A9B7CC"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
                        <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
                        <path d="M10 9H8"></path>
                        <path d="M16 13H8"></path>
                        <path d="M16 17H8"></path>
                    </svg>
                    <p class="at-empty">Select a ticket to view details</p>
                </div>
            }
            else
            {
                <div class="at-card">

                    <!-- DETAIL HEADER -->
                    <div class="at-card__header">
                        <div>
                            <span class="at-ticket-number">
                                @selectedTicket.TicketNumber
                            </span>
                            <span class="at-badge @GetStatusClass(selectedTicket.Status)"
                                  style="margin-left:8px">
                                @GetStatusDisplay(selectedTicket.Status)
                            </span>
                        </div>
                        <span class="at-badge @GetPriorityClass(selectedTicket.Priority)">
                            @GetPriorityDisplay(selectedTicket.Priority)
                        </span>
                    </div>

                    <div class="at-card__body">

                        <!-- SUBJECT -->
                        <h2 class="at-detail__subject">
                            @selectedTicket.Subject
                        </h2>

                        <!-- META -->
                        <div class="at-detail__meta">
                            <div class="at-detail__meta-row">
                                <span class="at-detail__meta-label">From</span>
                                <span class="at-detail__meta-value">
                                    @selectedTicket.Name
                                </span>
                            </div>
                            <div class="at-detail__meta-row">
                                <span class="at-detail__meta-label">Email</span>
                                <span class="at-detail__meta-value">
                                    @selectedTicket.Email
                                </span>
                            </div>
                            <div class="at-detail__meta-row">
                                <span class="at-detail__meta-label">Category</span>
                                <span class="at-detail__meta-value">
                                    @selectedTicket.Category
                                </span>
                            </div>
                            <div class="at-detail__meta-row">
                                <span class="at-detail__meta-label">Submitted</span>
                                <span class="at-detail__meta-value">
                                    @selectedTicket.CreatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                </span>
                            </div>
                        </div>

                        <!-- MESSAGE -->
                        <div class="at-detail__message">
                            <p class="at-detail__message-label">Message</p>
                            <p class="at-detail__message-body">
                                @selectedTicket.Message
                            </p>
                        </div>

                        <!-- STATUS ACTIONS -->
                        @if (!string.IsNullOrEmpty(statusError))
                        {
                            <p class="at-detail__error">@statusError</p>
                        }

                        <div class="at-detail__actions">
                            @if (selectedTicket.Status == "open")
                            {
                                <button class="at-btn at-btn--primary"
                                        @onclick='() => HandleUpdateStatus("in_progress")'
                                        disabled="@isUpdating">
                                    @(isUpdating ? "Updating..." : "Mark In Progress")
                                </button>
                                <button class="at-btn at-btn--success"
                                        @onclick='() => HandleUpdateStatus("resolved")'
                                        disabled="@isUpdating">
                                    Mark Resolved
                                </button>
                            }
                            else if (selectedTicket.Status == "in_progress")
                            {
                                <button class="at-btn at-btn--success"
                                        @onclick='() => HandleUpdateStatus("resolved")'
                                        disabled="@isUpdating">
                                    @(isUpdating ? "Updating..." : "Mark Resolved")
                                </button>
                                <button class="at-btn at-btn--ghost"
                                        @onclick='() => HandleUpdateStatus("open")'
                                        disabled="@isUpdating">
                                    Reopen
                                </button>
                            }
                            else if (selectedTicket.Status == "resolved")
                            {
                                <button class="at-btn at-btn--ghost"
                                        @onclick='() => HandleUpdateStatus("open")'
                                        disabled="@isUpdating">
                                    @(isUpdating ? "Updating..." : "Reopen Ticket")
                                </button>
                            }
                        </div>

                    </div>
                </div>
            }
        </div>

    </div>

</div>

@code {

    // ─── STATE ────────────────────────────────────────────────
    private List<SupportTicketModel> tickets = new();
    private SupportTicketModel? selectedTicket = null;
    private TicketStatsModel? stats;
    private bool isLoading = true;
    private bool isUpdating = false;
    private string activeStatus = string.Empty;
    private string statusError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // ✅ load stats and tickets in parallel
        await Task.WhenAll(LoadTickets(), LoadStats());
    }

    // ─── LOAD ─────────────────────────────────────────────────
    private async Task LoadTickets()
    {
        isLoading = true;
        StateHasChanged();

        var result = await HelpCenterService.GetAllTickets(
            string.IsNullOrEmpty(activeStatus) ? null : activeStatus,
            1, 50);

        if (result.Success && result.Data != null)
            tickets = result.Data.Data;

        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadStats()
    {
        var result = await HelpCenterService.GetStats();
        if (result.Success && result.Data != null)
            stats = result.Data;
        StateHasChanged();
    }

    // ─── FILTER ───────────────────────────────────────────────
    private async Task HandleStatusFilter(ChangeEventArgs e)
    {
        activeStatus = e.Value?.ToString() ?? string.Empty;
        selectedTicket = null;
        await LoadTickets();
    }

    // ─── SELECT TICKET ────────────────────────────────────────
    private void SelectTicket(SupportTicketModel ticket)
    {
        selectedTicket = ticket;
        statusError = string.Empty;
        StateHasChanged();
    }

    // ─── UPDATE STATUS ────────────────────────────────────────
    private async Task HandleUpdateStatus(string status)
    {
        if (selectedTicket == null) return;

        statusError = string.Empty;
        isUpdating = true;
        StateHasChanged();

        var result = await HelpCenterService.UpdateTicketStatus(
            selectedTicket.Id, status);

        if (result.Success && result.Data != null)
        {
            // ✅ update local list + selected ticket immediately
            selectedTicket.Status = status;

            var index = tickets.FindIndex(
                t => t.Id == selectedTicket.Id);
            if (index != -1)
                tickets[index].Status = status;

            // ✅ refresh stats after status change
            await LoadStats();
        }
        else
        {
            statusError = result.Message
                          ?? "Failed to update status.";
        }

        isUpdating = false;
        StateHasChanged();
    }

    // ─── HELPERS ──────────────────────────────────────────────
    private string GetStatusClass(string? status) => status switch
    {
        "open" => "at-badge--open",
        "in_progress" => "at-badge--progress",
        "resolved" => "at-badge--resolved",
        _ => "at-badge--open"
    };

    private string GetStatusDisplay(string? status) => status switch
    {
        "open" => "Open",
        "in_progress" => "In Progress",
        "resolved" => "Resolved",
        _ => status ?? "Unknown"
    };

    private string GetPriorityClass(string? priority) => priority switch
    {
        "high" => "at-badge--high",
        "normal" => "at-badge--normal",
        _ => "at-badge--normal"
    };

    private string GetPriorityDisplay(string? priority) => priority switch
    {
        "high" => "High",
        "normal" => "Normal",
        _ => priority ?? "Normal"
    };
}
