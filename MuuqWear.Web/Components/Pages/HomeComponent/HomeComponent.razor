@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@using MuuqWear.Application.Services.CategoryService
@using MuuqWear.Application.Services.JobPostingService
@using MuuqWear.Application.Services.ProductService
@using MuuqWear.Model.Products
@using MuuqWear.Web.Components.Shared
@inject IProductService ProductService
@inject ICategoryService CategoryService


<PageTitle>Home</PageTitle>

<!-- Hero Section -->
<section class="mw-hero-section">
    <div class="swiper mw-hero">
        <div class="swiper-wrapper">
            @foreach (var slide in HeroSlides)
            {
                <div class="swiper-slide">
                    <div class="mw-slide">
                        <img src="@slide.Image" alt="@slide.Headline" class="mw-slide__img" />
                        <div class="mw-slide__overlay"></div>
                        <div class="mw-slide__content">
                            <p class="mw-slide__label">@slide.Eyebrow</p>
                            <h1 class="mw-slide__title">@slide.Headline</h1>
                            <a href="@slide.Link" class="mw-slide__cta">
                                @slide.Cta
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M5 12h14" />
                                    <path d="m12 5 7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <button type="button" class="mw-hero-nav mw-hero-nav--prev" aria-label="Previous slide">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
        </svg>
    </button>
    <button type="button" class="mw-hero-nav mw-hero-nav--next" aria-label="Next slide">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
        </svg>
    </button>

    <div class="mw-hero-progress" aria-hidden="true">
        @for (var i = 0; i < HeroSlides.Count; i++)
        {
            <div class="mw-hero-progress__segment">
                <div class="mw-hero-progress__fill"></div>
            </div>
        }
    </div>
</section>

<!-- Shop by Category -->
<section class="mw-home-section mw-home-section--muted">
    <div class="mw-home-container">
        <div class="mw-carousel-section" data-carousel="category">
            <div class="mw-carousel-section__header">
                <div>
                    <h2 class="mw-carousel-section__title">Shop by Category</h2>
                    <div class="mw-carousel-section__underline"></div>
                </div>
                <div class="mw-carousel-section__controls">
                    <button type="button" class="mw-carousel-section__prev" aria-label="Previous categories">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m15 18-6-6 6-6" />
                        </svg>
                    </button>
                    <button type="button" class="mw-carousel-section__next" aria-label="Next categories">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="swiper mw-home-swiper">
                <div class="swiper-wrapper">
                    @foreach (var (item, idx) in Categories.Select((c, i) => (c, i)))
                    {
                        <div class="swiper-slide">
                            <a href="@item.Link" class="mw-category__card">
                                <img src="@item.Image" alt="@item.Name" loading="@(idx < 3 ? null : "lazy")" />
                                <div class="mw-category__overlay"></div>
                                <div class="mw-category__content">
                                    <h3>@item.Name</h3>
                                    <span class="mw-category__cta">
                                        Shop Now
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M5 12h14" />
                                            <path d="m12 5 7 7-7 7" />
                                        </svg>
                                    </span>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- New Arrivals -->
<section class="mw-home-section">
    <div class="mw-home-container">
        <div class="mw-carousel-section" data-carousel="product">
            <div class="mw-carousel-section__header">
                <div>
                    <h2 class="mw-carousel-section__title">New Arrivals</h2>
                    <div class="mw-carousel-section__underline"></div>
                </div>
                <div class="mw-carousel-section__controls">
                    <button type="button" class="mw-carousel-section__prev" aria-label="Previous new arrivals">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m15 18-6-6 6-6" />
                        </svg>
                    </button>
                    <button type="button" class="mw-carousel-section__next" aria-label="Next new arrivals">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="swiper mw-home-swiper">
                <div class="swiper-wrapper">
                    @foreach (var (item, idx) in NewArrivals.Select((p, i) => (p, i)))
                    {
                        <div class="swiper-slide">
                            <div class="mw-product-card">
                                <div class="mw-product-card__image">
                                    <a href="/productdetail/@item.Id" class="mw-product-card__media-link">
                                        <img src="@item.ImageUrl" alt="@item.Name" loading="@(idx < 4 ? null : "lazy")" />
                                        <div class="mw-product-card__badge">NEW</div>
                                    </a>
                                    <WishlistButtonComponent ProductId="@item.Id"
                                                             ProductName="@item.Name"
                                                             ProductImageUrl="@item.ImageUrl"
                                                             ProductPrice="@item.Price"
                                                             CssClass="mw-wishlist-btn--overlay"
                                                             Size="16" />
                                </div>
                                <a href="/productdetail/@item.Id" class="mw-product-card__body">
                                    <h3 class="mw-product-card__name">@item.Name</h3>
                                    <p class="mw-product-card__price">$@item.Price.ToString("F2")</p>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Collections -->
<section class="mw-home-section mw-home-section--muted">
    <div class="mw-home-container">
        <div class="mw-carousel-section" data-carousel="collection">
            <div class="mw-carousel-section__header">
                <div>
                    <h2 class="mw-carousel-section__title">Featured Collections</h2>
                    <div class="mw-carousel-section__underline"></div>
                </div>
                <div class="mw-carousel-section__controls">
                    <button type="button" class="mw-carousel-section__prev" aria-label="Previous featured collections">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m15 18-6-6 6-6" />
                        </svg>
                    </button>
                    <button type="button" class="mw-carousel-section__next" aria-label="Next featured collections">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="swiper mw-home-swiper">
                <div class="swiper-wrapper">
                    @foreach (var (item, idx) in FeaturedProducts.Select((p, i) => (p, i)))
                    {
                        <div class="swiper-slide">
                            <div class="mw-featured__card">
                                <div class="mw-featured__img-wrap">
                                    <a href="/productdetail/@item.Id">
                                        <img src="@item.ImageUrl" alt="@item.Name" loading="@(idx < 2 ? null : "lazy")" />
                                    </a>
                                </div>
                                <div class="mw-featured__content">
                                    <h3>@item.Name</h3>
                                    <p class="mw-featured__desc">
                                        @(string.IsNullOrWhiteSpace(item.Description)
                                            ? "Discover our curated collection of premium essentials."
                                            : item.Description)
                                    </p>
                                    <a href="/productdetail/@item.Id" class="mw-featured__link">Shop Collection</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Value Props -->
<section class="mw-benefits">
    <div class="mw-home-container">
        <div class="mw-benefits__grid">
            <div class="mw-benefits__item">
                <div class="mw-benefits__icon">
                    <svg width="24" height="24" fill="none" stroke="#1E2A47" stroke-width="2" aria-hidden="true">
                        <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
                        <path d="M15 18H9"></path>
                        <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path>
                        <circle cx="17" cy="18" r="2"></circle>
                        <circle cx="7" cy="18" r="2"></circle>
                    </svg>
                </div>
                <div>
                    <h3>Free Shipping</h3>
                    <p>Complimentary on orders over $150</p>
                </div>
            </div>

            <div class="mw-benefits__item">
                <div class="mw-benefits__icon">
                    <svg width="24" height="24" fill="none" stroke="#1E2A47" stroke-width="2" aria-hidden="true">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                        <path d="M3 3v5h5"></path>
                    </svg>
                </div>
                <div>
                    <h3>30-Day Returns</h3>
                    <p>Hassle-free exchange policy</p>
                </div>
            </div>

            <div class="mw-benefits__item">
                <div class="mw-benefits__icon">
                    <svg width="24" height="24" fill="none" stroke="#1E2A47" stroke-width="2" aria-hidden="true">
                        <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                    </svg>
                </div>
                <div>
                    <h3>Secure Checkout</h3>
                    <p>AES-256 encrypted payments</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Bestsellers -->
<section class="mw-home-section">
    <div class="mw-home-container">
        <div class="mw-carousel-section" data-carousel="product">
            <div class="mw-carousel-section__header mw-carousel-section__header--with-link">
                <div>
                    <h2 class="mw-carousel-section__title">Bestsellers</h2>
                    <div class="mw-carousel-section__underline"></div>
                </div>
                <div class="mw-carousel-section__header-right">
                    <a href="/shop/apparel" class="mw-view-all-link">View All Products</a>
                    <div class="mw-carousel-section__controls">
                        <button type="button" class="mw-carousel-section__prev" aria-label="Previous bestsellers">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="m15 18-6-6 6-6" />
                            </svg>
                        </button>
                        <button type="button" class="mw-carousel-section__next" aria-label="Next bestsellers">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="m9 18 6-6-6-6" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="swiper mw-home-swiper">
                <div class="swiper-wrapper">
                    @foreach (var (item, idx) in BestSellerProducts.Select((p, i) => (p, i)))
                    {
                        <div class="swiper-slide">
                            <div class="mw-product-card">
                                <div class="mw-product-card__image">
                                    <a href="/productdetail/@item.Id" class="mw-product-card__media-link">
                                        <img src="@item.ImageUrl" alt="@item.Name" loading="@(idx < 4 ? null : "lazy")" />
                                        @if (!string.IsNullOrEmpty(item.Badge))
                                        {
                                            <div class="mw-product-card__badge">@item.Badge</div>
                                        }
                                    </a>
                                    <WishlistButtonComponent ProductId="@item.Id"
                                                             ProductName="@item.Name"
                                                             ProductImageUrl="@item.ImageUrl"
                                                             ProductPrice="@item.Price"
                                                             CssClass="mw-wishlist-btn--overlay"
                                                             Size="16" />
                                </div>
                                <a href="/productdetail/@item.Id" class="mw-product-card__body">
                                    <h3 class="mw-product-card__name">@item.Name</h3>
                                    <p class="mw-product-card__price">$@item.Price.ToString("F2")</p>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
