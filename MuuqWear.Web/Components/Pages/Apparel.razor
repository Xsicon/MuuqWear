    void OpenFilters() => isFilterOpen = true;
    void CloseFilters() => isFilterOpen = false;
    public class Product
    {
        public string Image { get; set; }
        public string Category { get; set; }
        public string Title { get; set; }
        public decimal Price { get; set; }
    }

    private List<Product> Products = new()
    {
        new Product
        {
            Image = "https://images.unsplash.com/photo-1704716720991-cf3197cfb190?w=400&h=500&fit=crop",
            Category = "Outerwear",
            Title = "Elements Waterproof Parka",
            Price = 185
        },
        new Product
        {
            Image = "https://images.unsplash.com/photo-1642853474532-9aca78f70629?w=400&h=500&fit=crop",
            Category = "Knitwear",
            Title = "Merino Essential Crew",
            Price = 72
        },
        new Product
        {
            Image = "https://images.unsplash.com/photo-1555689502-c4b22d76c56f?w=400&h=500&fit=crop",
            Category = "Trousers",
            Title = "Raw Selvedge Denim",
            Price = 120
        },
        new Product
        {
            Image = "https://images.unsplash.com/photo-1620231151282-957594b30e94?w=400&h=500&fit=crop",
            Category = "Outerwear",
            Title = "Utility Field Jacket",
            Price = 145
        },
        new Product
        {
