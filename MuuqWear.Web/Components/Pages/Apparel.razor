@page "/shop/apparel"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Apparel</PageTitle>
<section class="mw-shop container py-4 py-md-5">

    <!-- BREADCRUMB -->
    <div class="mw-breadcrumb small text-muted mb-2">
        <a href="/" class="text-decoration-none">Home</a>
        <span class="mx-2">/</span>
        <span class="fw-bold text-dark">Shop All</span>
    </div>

    <!-- TITLE -->
    <h1 class="mw-title">Shop All</h1>

    <!-- DESCRIPTION -->
    <p class="mw-desc">
        Discover our curated collection of technical outerwear, premium knitwear,
        and essential accessories designed for the modern explorer.
    </p>

    <!-- MOBILE FILTER BUTTON -->
    <button class="d-flex align-items-center mw-filter-btn bg-transparent"
            @onclick="OpenFilters">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" class="lucide lucide-sliders-horizontal"
             data-fg-bygr45="1.222:34.7576:/src/app/pages/Shop.tsx:129:11:5723:31:e:SlidersHorizontal::::::EGFQ"
             data-fgid-bygr45=":rne:">
            <line x1="21" x2="14" y1="4" y2="4"></line>
            <line x1="10" x2="3" y1="4" y2="4">

            </line>
            <line x1="21" x2="12" y1="12" y2="12">

            </line>
            <line x1="8" x2="3" y1="12" y2="12"></line>
            <line x1="21" x2="16" y1="20" y2="20">

            </line>
            <line x1="12" x2="3" y1="20" y2="20"></line>
            <line x1="14" x2="14" y1="2" y2="6">

            </line>
            <line x1="8" x2="8" y1="10" y2="14"></line>
            <line x1="16" x2="16" y1="18" y2="22">

            </line>
        </svg>
        <span>Filters</span>
    </button>

    <div class="row g-4">

        <!-- SIDEBAR (DESKTOP ONLY) -->
        <aside class="col-lg-3 d-none d-lg-block">
            <div class="mw-filter">

                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold">Filters</h5>
                    <button class="btn btn-sm text-muted">Clear All</button>
                </div>

                <!-- CATEGORY -->
                <div class="mb-4">
                    <h6 class="mw-filter-title">Categories</h6>

                    <div class="mw-check">
                        <input type="checkbox" id="outerwear" />
                        <label for="outerwear">Outerwear</label>
                    </div>

                    <div class="mw-check">
                        <input type="checkbox" id="knitwear" />
                        <label for="knitwear">Knitwear</label>
                    </div>

                    <div class="mw-check">
                        <input type="checkbox" id="accessories" />
                        <label for="accessories">Accessories</label>
                    </div>
                </div>

                <!-- SIZE -->
                <div class="mb-4">
                    <h6 class="mw-filter-title">Size</h6>

                    <div class="mw-size-grid">
                        <button class="mw-size">XS</button>
                        <button class="mw-size active">S</button>
                        <button class="mw-size">M</button>
                        <button class="mw-size">L</button>
                        <button class="mw-size">XL</button>
                        <button class="mw-size">XXL</button>
                    </div>
                </div>

                <!-- PRICE -->
                <div>
                    <h6 class="mw-filter-title">Price</h6>
                    <div class="mw-price">

                        <div class="d-flex justify-content-between small mb-2">
                            <span>$0</span>
                            <span>$500+</span>
                        </div>

                        <input type="range" class="mw-range" />
                    </div>
                </div>

            </div>
        </aside>

        <!-- PRODUCTS -->
        <div class="col-12 col-lg-9">

            <!-- TOP BAR -->
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                <p class="text-muted small mb-0">
                    Showing <span class="fw-bold text-dark">6</span> products
                </p>

                <select class="form-select w-auto">
                    <option>Featured</option>
                    <option>Price: Low to High</option>
                </select>
            </div>

            <!-- GRID -->
            <div class="row g-3 g-md-4">

                @foreach (var item in Products)
                {
                    <div class="col-6 col-lg-4">

                        <div class="mw-product">

                            <div class="mw-product-img">
                                <img src="@item.Image" />
                            </div>

                            <p class="mw-product-category">@item.Category</p>

                            <h6 class="mw-product-title">@item.Title</h6>

                            <p class="mw-product-price">$@item.Price</p>

                        </div>

                    </div>
                }

            </div>

            <!-- PAGINATION -->
            <div class="d-flex justify-content-center mt-5 gap-2">

                <button class="mw-page-btn">‹</button>
                <button class="mw-page-btn active">1</button>
                <button class="mw-page-btn">2</button>
                <button class="mw-page-btn">›</button>

            </div>

        </div>

    </div>

</section>

<div class="mw-filter-overlay @(isFilterOpen ? "open" : "")"
     @onclick="CloseFilters">

    <!-- DRAWER -->
    <div class="mw-filter-drawer" @onclick:stopPropagation="true">

        <!-- HEADER -->
        <div class="mw-filter-header d-flex justify-content-between align-items-center">
            <h5 class="fw-bold">Filters</h5>
            <button class="mw-filter-close" @onclick="CloseFilters">✕</button>
        </div>

        <!-- CONTENT (REUSE SAME FILTER UI) -->
        <div class="mw-filter-body">

            <!--COPY SAME FILTER CONTENT -->
            <div class="mw-filter">

                <div class="d-flex justify-content-between mb-3">
                    <h6 class="fw-bold">Filters</h6>
                    <button class="btn btn-sm text-muted">Clear All</button>
                </div>

                <!-- CATEGORY -->
                <div class="mb-4">
                    <h6 class="mw-filter-title">Categories</h6>

                    <div class="mw-check">
                        <input type="checkbox" id="m_outerwear" />
                        <label for="m_outerwear">Outerwear</label>
                    </div>

                    <div class="mw-check">
                        <input type="checkbox" id="m_knitwear" />
                        <label for="m_knitwear">Knitwear</label>
                    </div>

                    <div class="mw-check">
                        <input type="checkbox" id="m_accessories" />
                        <label for="m_accessories">Accessories</label>
                    </div>
                </div>

                <!-- SIZE -->
                <div class="mb-4">
                    <h6 class="mw-filter-title">Size</h6>

                    <div class="mw-size-grid">
                        <button class="mw-size">XS</button>
                        <button class="mw-size active">S</button>
                        <button class="mw-size">M</button>
                        <button class="mw-size">L</button>
                        <button class="mw-size">XL</button>
                        <button class="mw-size">XXL</button>
                    </div>
                </div>

                <!-- PRICE -->
                <div>
                    <h6 class="mw-filter-title">Price Range</h6>

                    <div class="d-flex justify-content-between small mb-2">
                        <span>$0</span>
                        <span>$500+</span>
                    </div>

                    <input type="range" class="mw-range" />
                </div>

            </div>

        </div>

        <!-- FOOTER -->
        <div class="mw-filter-footer">
            <button class="btn btn-dark w-100">
                Apply Filters (6 products)
            </button>
        </div>

    </div>
</div>


@code {

