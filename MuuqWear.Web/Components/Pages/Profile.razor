@page "/profile"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using MuuqWear.Application.Interfaces
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Application.Services.CartService
@using MuuqWear.Application.Services.OrderService
@using MuuqWear.Application.Shared
@using MuuqWear.Model.Authentication
@using Microsoft.AspNetCore.Components.Authorization
@using MuuqWear.Model.Orders
@inject IOrderService OrderService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject IAuthService IAuthService
@inject NavigationManager NavigationManager
@inject CartStateService CartStateService
@attribute [Authorize(Roles = "user")]
@using MuuqWear.Model.Address
@using MuuqWear.Application.Services.AddressService
@inject IAddressService AddressService
@using MuuqWear.Model.Profile
@using MuuqWear.Application.Services.ProfileService
@inject IProfileService ProfileService
@using System.Net.Http
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject AuthSessionService AuthSession


<PageTitle>Profile</PageTitle>

<section class="mw-profile container py-4 py-md-5">

    <!-- MOBILE HEADER -->
    <div class="d-md-none mb-3">
        <button class="mw-profile-mobile-toggle"
                @onclick="() => isMobileMenuOpen = !isMobileMenuOpen">
            <span>@GetActiveTabLabel()</span>
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="16"
                 height="16"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="2"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 style="transform: rotate(@(isMobileMenuOpen ? "180deg" : "0deg")); transition: transform 0.2s">
                <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
        </button>
    </div>


    @if (isMobileMenuOpen)
    {
        <div class="mw-mobile-menu d-md-none mb-3">

            <!-- USER INFO -->
            <div class="mw-mobile-menu__user">
                <div class="mw-avatar">SA</div>
                <div>
                    <h6 class="mw-user-name">@LoggedInUserName</h6>
                    <p class="mw-user-meta">Member since October 2024</p>
                </div>
            </div>

            <!-- NAV ITEMS -->
            <nav class="mw-mobile-menu__nav">
                <button class="mw-mobile-nav-item @(activeTab == "overview" ? "active" : "")"
                        @onclick='() => SelectTab("overview")'>
                    Overview
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "orders" ? "active" : "")"
                        @onclick='() => SelectTab("orders")'>
                    Orders
                </button>
                <button class="mw-mobile-nav-item">
                    Wishlist
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "addresses" ? "active" : "")"
                        @onclick='() => SelectTab("addresses")'>
                    Addresses
                </button>
                <button class="mw-mobile-nav-item">
                    Affiliate Hub
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "settings" ? "active" : "")"
                        @onclick='() => SelectTab("settings")'>
                    Settings
                </button>
            </nav>

            <!-- AFFILIATE STATUS -->
            <div class="mw-mobile-menu__affiliate">
                <p class="mw-affiliate-label">Affiliate Status</p>
                <p class="mw-affiliate-value">⭐ Silver</p>
            </div>

            <!-- SIGN OUT -->
            <button class="mw-mobile-menu__signout" @onclick="HandleSignOut">
                Sign Out
            </button>

        </div>
    }



    <div class="row g-4">

        <!-- SIDEBAR -->
        <aside class="col-md-4 col-lg-3 d-none d-md-block">

            <!-- USER INFO -->
            <div class="mw-profile-user text-md-end">
                <div class="mw-avatar">SA</div>
                <h6 class="mw-user-name">@LoggedInUserName</h6>
                <p class="mw-user-meta">Member since October 2024</p>
            </div>

            <!-- NAV -->
            <nav class="mw-profile-nav">
                <button class="mw-nav-item @(activeTab == "overview" ? "active" : "")"
                        @onclick='() => activeTab = "overview"'>
                    Overview
                </button>
                <button class="mw-nav-item @(activeTab == "orders" ? "active" : "")"
                        @onclick='() => activeTab = "orders"'>
                    Orders
                </button>
                <button class="mw-nav-item">Wishlist</button>
                <button class="mw-nav-item @(activeTab == "addresses" ? "active" : "")"
                        @onclick='() => activeTab = "addresses"'>
                    Addresses
                </button>
                <button class="mw-nav-item">Affiliate Hub</button>
                <button class="mw-nav-item @(activeTab == "settings" ? "active" : "")"
                        @onclick='() => activeTab = "settings"'>
                    Settings
                </button>
            </nav>

            <!-- AFFILIATE -->
            <div class="mw-affiliate">
                <p class="mw-affiliate-label">Affiliate Status</p>
                <p class="mw-affiliate-value">⭐ Silver</p>
            </div>

            <!-- SIGN OUT -->
            <button class="mw-signout" @onclick="HandleSignOut">Sign Out</button>

        </aside>

        <!-- MAIN CONTENT -->
        <!-- MAIN CONTENT -->
        <div class="col-12 col-md-8 col-lg-9">

            <!-- WELCOME — always visible -->
            @if (activeTab == "overview")
            {
                <div class="mb-4">
                    <h2 class="mw-welcome">Welcome back, @LoggedInUserName</h2>
                    <p class="mw-subtext">Here's your Muuqwear at a glance.</p>
                </div>

                <!-- STATS -->
                <div class="row g-3 mb-4">
                    <!-- ... your stat cards ... -->
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <p class="mw-stat-value">@userOrders.Count</p>
                            <p class="mw-stat-label">Orders</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <p class="mw-stat-value">4</p>
                            <p class="mw-stat-label">Wishlist</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <p class="mw-stat-value">Silver</p>
                            <p class="mw-stat-label">Affiliate Tier</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <p class="mw-stat-value">$1251</p>
                            <p class="mw-stat-label">Total Spent</p>
                        </div>
                    </div>
                </div>

                <!-- RECENT ORDERS -->
                <div class="mw-orders">
                    <p class="mw-section-title">Recent Orders</p>
                    <OrdersList Orders="userOrders.Take(3).ToList()" />
                </div>
            }
            else if (activeTab == "orders")
            {
                <div class="mw-orders">
                    <p class="mw-section-title">All Orders</p>
                    <OrdersList Orders="userOrders" />
                </div>
            }

            else if (activeTab == "addresses")
            {
                <!-- HEADER -->
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <p style="color:#1E2A47;font-size:24px;
                                                                                                                                                                                                                                                                                                                  font-family:'Playfair Display',serif;margin:0">
                        Saved Addresses
                    </p>
                    <button @onclick="OpenAddForm" style="display:flex;align-items:center;gap:6px;
                                                                                                                                                                                       border:1px solid #1E2A47;color:#1E2A47;
                                                                                                                                                                                       padding:8px 16px;font-size:12px;font-weight:700;
                                                                                                                                                                                       text-transform:uppercase;letter-spacing:0.5px;
                                                                                                                                                                                       background:transparent">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14"></path>
                            <path d="M12 5v14"></path>
                        </svg>
                        Add New
                    </button>
                </div>

                <!-- EMPTY STATE -->
                @if (!addresses.Any())
                {
                    <p style="color:#4A5C7A;font-size:14px">
                        No saved addresses yet. Add one to get started.
                    </p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var address in addresses)
                        {
                            <div class="col-12 col-md-6">
                                <div class="h-100"
                                     style="border:1px solid @(address.IsDefault ? "#1E2A47" : "rgba(169,183,204,0.4)");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                padding:21px">

                                    <!-- header -->
                                    <div class="d-flex align-items-center
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    justify-content-between mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <p style="color:#1E2A47;font-size:14px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          font-weight:700;margin:0">
                                                @address.Label
                                            </p>
                                            @if (address.IsDefault)
                                            {
                                                <span style="font-size:10px;background:#1E2A47;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 color:white;padding:2px 8px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 text-transform:uppercase;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 font-weight:700;letter-spacing:0.5px">
                                                    Default
                                                </span>
                                            }
                                        </div>
                                        <button @onclick="() => EditAddress(address)"
                                                style="color:#4A5C7A;background:transparent;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           border:none;padding:0">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round"
                                                 stroke-linejoin="round">
                                                <path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"></path>
                                            </svg>
                                        </button>
                                    </div>

                                    <!-- address lines -->
                                    <p style="color:#4A5C7A;font-size:13px;margin:0">
                                        @address.FullName
                                    </p>
                                    <p style="color:#4A5C7A;font-size:13px;margin:0">
                                        @address.Street1
                                    </p>
                                    @if (!string.IsNullOrEmpty(address.Street2))
                                    {
                                        <p style="color:#4A5C7A;font-size:13px;margin:0">
                                            @address.Street2
                                        </p>
                                    }
                        <p style="color:#4A5C7A;font-size:13px;margin:0">
                            @address.City@(string.IsNullOrEmpty(address.State)
                                                        ? "" : $", {address.State}") @address.PostalCode
                        </p>

                                    <!-- set as default -->
                        @if (!address.IsDefault)
                                    {
                                        <button @onclick="() => HandleSetDefault(address.Id)"
                                                style="margin-top:10px;font-size:12px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           color:#1E2A47;font-weight:700;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           text-decoration:underline;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           background:transparent;border:none;padding:0">
                                            Set as Default
                                        </button>
                                    }

                                </div>
                            </div>
                        }
                    </div>
                }
            }

            else if (activeTab == "settings")
            {
                <div style="display:flex;flex-direction:column;gap:34px">

                    <!-- SECTION 1: PROFILE -->
                    <div style="border:1px solid rgba(169,183,204,0.4);padding:21px">
                        <p style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
                                                                                                                                                                      font-weight:700;color:#4A5C7A;margin-bottom:13px">
                            Profile
                        </p>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label style="font-size:11px;letter-spacing:1.5px;
                                                                                                                                                                                  text-transform:uppercase;font-weight:700;
                                                                                                                                                                                  color:#4A5C7A;display:block;margin-bottom:5px">
                                    Full Name
                                </label>
                                <input @bind="settingsFullName" style="width:100%;border:1px solid rgba(169,183,204,0.4);
                                                                                                                                                                                  padding:10px 13px;font-size:14px;color:#1E2A47;
                                                                                                                                                                                  outline:none" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label style="font-size:11px;letter-spacing:1.5px;
                                                                                                                                                                                  text-transform:uppercase;font-weight:700;
                                                                                                                                                                                  color:#4A5C7A;display:block;margin-bottom:5px">
                                    Email
                                </label>
                                <input @bind="settingsEmail" style="width:100%;border:1px solid rgba(169,183,204,0.4);
                                                                                                                                                                                  padding:10px 13px;font-size:14px;color:#1E2A47;
                                                                                                                                                                                  outline:none" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(settingsError))
                        {
                            <p style="color:#C44545;font-size:13px;margin-top:12px;margin-bottom:0">
                                @settingsError
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(settingsSuccess))
                        {
                            <p style="color:#1D9E75;font-size:13px;margin-top:12px;margin-bottom:0">
                                @settingsSuccess
                            </p>
                        }

                        <button @onclick="HandleSaveSettings"
                                disabled="@isSavingSettings"
                                style="margin-top:16px;background:#1E2A47;color:white;
                                                                                                                                                   padding:10px 34px;font-size:13px;font-weight:700;
                                                                                                                                                   letter-spacing:0.5px;text-transform:uppercase;border:none;
                                                                                                                                                   opacity:@(isSavingSettings ? "0.7" : "1")">
                            @(isSavingSettings ? "Saving..." : "Save Changes")
                        </button>
                    </div>

                    <!-- SECTION 2: NOTIFICATIONS -->
                    <div style="border:1px solid rgba(169,183,204,0.4);padding:21px">
                        <p style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
                                                                                                                                                                      font-weight:700;color:#4A5C7A;margin-bottom:13px">
                            Notifications
                        </p>

                        <!-- Email Notifications -->
                        <div style="display:flex;align-items:center;justify-content:space-between;
                                                                                                                                                                        padding:13px 0;border-bottom:1px solid rgba(169,183,204,0.1)">
                            <div>
                                <p style="color:#1E2A47;font-size:14px;font-weight:600;margin:0">
                                    Email Notifications
                                </p>
                                <p style="color:#4A5C7A;font-size:12px;margin:0">
                                    Order updates and tracking
                                </p>
                            </div>
                            <div @onclick="() => emailNotifications = !emailNotifications"
                                 style="width:44px;height:24px;border-radius:999px;cursor:pointer;
                                                                                                                                                                            background:@(emailNotifications ? "#1E2A47" : "#A9B7CC");
                                                                                                                                                                            position:relative;transition:background 0.2s">
                                <span style="position:absolute;top:2px;
                                                                                                                                                                                 left:@(emailNotifications ? "22px" : "2px");
                                                                                                                                                                                 width:20px;height:20px;border-radius:50%;
                                                                                                                                                                                 background:white;transition:left 0.2s">
                                </span>
                            </div>
                        </div>

                        <!-- SMS Notifications -->
                        <div style="display:flex;align-items:center;justify-content:space-between;
                                                                                                                                                                        padding:13px 0;border-bottom:1px solid rgba(169,183,204,0.1)">
                            <div>
                                <p style="color:#1E2A47;font-size:14px;font-weight:600;margin:0">
                                    SMS Notifications
                                </p>
                                <p style="color:#4A5C7A;font-size:12px;margin:0">
                                    Shipping alerts via text
                                </p>
                            </div>
                            <div @onclick="() => smsNotifications = !smsNotifications"
                                 style="width:44px;height:24px;border-radius:999px;cursor:pointer;
                                                                                                                                                                            background:@(smsNotifications ? "#1E2A47" : "#A9B7CC");
                                                                                                                                                                            position:relative;transition:background 0.2s">
                                <span style="position:absolute;top:2px;
                                                                                                                                                                                 left:@(smsNotifications ? "22px" : "2px");
                                                                                                                                                                                 width:20px;height:20px;border-radius:50%;
                                                                                                                                                                                 background:white;transition:left 0.2s">
                                </span>
                            </div>
                        </div>

                        <!-- Promotional Emails -->
                        <div style="display:flex;align-items:center;justify-content:space-between;
                                                                                                                                                                        padding:13px 0">
                            <div>
                                <p style="color:#1E2A47;font-size:14px;font-weight:600;margin:0">
                                    Promotional Emails
                                </p>
                                <p style="color:#4A5C7A;font-size:12px;margin:0">
                                    New drops, sales, and events
                                </p>
                            </div>
                            <div @onclick="() => promotionalEmails = !promotionalEmails"
                                 style="width:44px;height:24px;border-radius:999px;cursor:pointer;
                                                                                                                                                                            background:@(promotionalEmails ? "#1E2A47" : "#A9B7CC");
                                                                                                                                                                            position:relative;transition:background 0.2s">
                                <span style="position:absolute;top:2px;
                                                                                                                                                                                 left:@(promotionalEmails ? "22px" : "2px");
                                                                                                                                                                                 width:20px;height:20px;border-radius:50%;
                                                                                                                                                                                 background:white;transition:left 0.2s">
                                </span>
                            </div>
                        </div>

                    </div>

                    <!-- SECTION 3: DANGER ZONE -->
                    <div style="border:1px solid rgba(196,69,69,0.3);padding:21px">
                        <p style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
                                                      font-weight:700;color:#C44545;margin-bottom:8px">
                            Danger Zone
                        </p>
                        <p style="color:#4A5C7A;font-size:13px;margin-bottom:13px">
                            Permanently delete your account and all associated data.
                        </p>

                        @if (!showDeleteConfirm)
                        {
                            <!-- initial button -->
                            <button @onclick="() => showDeleteConfirm = true"
                                    style="border:1px solid #C44545;color:#C44545;
                                                                                                       padding:8px 21px;font-size:12px;font-weight:700;
                                                                                                       text-transform:uppercase;letter-spacing:0.5px;
                                                                                                       background:transparent">
                                Delete Account
                            </button>
                        }
                        else
                        {
                            <!-- confirmation step -->
                            <p style="color:#C44545;font-size:13px;font-weight:600;margin-bottom:12px">
                                Are you sure? This action cannot be undone.
                            </p>

                            @if (!string.IsNullOrEmpty(deleteError))
                            {
                                <p style="color:#C44545;font-size:13px;margin-bottom:12px">
                                    @deleteError
                                </p>
                            }

                            <div class="d-flex gap-2">
                                <button @onclick="HandleDeleteAccount"
                                        disabled="@isDeletingAccount"
                                        style="border:1px solid #C44545;background:#C44545;
                                                                                                           color:white;padding:8px 21px;font-size:12px;
                                                                                                           font-weight:700;text-transform:uppercase;
                                                                                                           letter-spacing:0.5px;
                                                                                                           opacity:@(isDeletingAccount ? "0.7" : "1")">
                                    @(isDeletingAccount ? "Deleting..." : "Yes, Delete")
                                </button>

                                <button @onclick="() => showDeleteConfirm = false"
                                        style="border:1px solid #1E2A47;color:#1E2A47;
                                                                                                           padding:8px 21px;font-size:12px;font-weight:700;
                                                                                                           text-transform:uppercase;letter-spacing:0.5px;
                                                                                                           background:transparent">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>

                </div>
            }
        </div>

    </div>
</section>

@if (isAddressFormOpen)
{
    <!-- OVERLAY -->
    <div @onclick="CloseAddressForm"
         style="position:fixed;inset:0;background:rgba(0,0,0,0.3);z-index:1000">
    </div>

    <!-- SLIDE IN PANEL -->
    <div style="position:fixed;top:0;right:0;height:100%;width:100%;
                                                                                                                                                                                                                                                                            max-width:480px;background:white;z-index:1001;
                                                                                                                                                                                                                                                                            overflow-y:auto;padding:32px 24px;
                                                                                                                                                                                                                                                                            box-shadow:-4px 0 24px rgba(0,0,0,0.1)">

        <!-- header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <p style="color:#1E2A47;font-size:20px;
                                                                                                                                                                                                                                                                                  font-family:'Playfair Display',serif;margin:0">
                @(isEditMode ? "Edit Address" : "Add New Address")
            </p>
            <button @onclick="CloseAddressForm"
                    style="background:transparent;border:none;
                                                                                                                                                                                                                                                                                       color:#4A5C7A;font-size:20px;padding:0">
                ✕
            </button>
        </div>

        <!-- error -->
        @if (!string.IsNullOrEmpty(addressFormError))
        {
            <p style="color:#dc3545;font-size:13px;margin-bottom:16px">
                @addressFormError
            </p>
        }

        <!-- FORM FIELDS -->
        <div class="d-flex flex-column gap-3">

            <!-- Label -->
            <div>
                <label style="color:#1E2A47;font-size:12px;
                                                                                                                                                                                                                        font-weight:700;text-transform:uppercase;
                                                                                                                                                                                                                        letter-spacing:0.5px">
                    Label *
                </label>
                <div class="d-flex gap-2 mt-1">
                    @foreach (var label in new[] { "Home", "Office", "Other" })
                    {
                        <button @onclick="() => addressForm.Label = label"
                                style="padding:6px 16px;font-size:12px;
                                                                                                                                                                                                                                                                                                                                                                                        font-weight:600;border:1px solid;
                                                                                                                                                                                                                                                                                                                                                                                        background:@(addressForm.Label == label ? "#1E2A47" : "transparent");
                                                                                                                                                                                                                                                                                                                                                                                        color:@(addressForm.Label == label ? "white" : "#1E2A47");
                                                                                                                                                                                                                                                                                                                                                                                        border-color:#1E2A47">
                            @label
                        </button>
                    }
                </div>
            </div>

            <!-- Full Name -->
            <div>
                <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                           text-transform:uppercase;letter-spacing:0.5px">
                    Full Name *
                </label>
                <input @bind="addressForm.FullName"
                       placeholder="John Smith"
                       style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                          border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                          font-size:14px;color:#1E2A47;outline:none" />
            </div>

            <!-- Street 1 -->
            <div>
                <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                           text-transform:uppercase;letter-spacing:0.5px">
                    Street Address *
                </label>
                <input @bind="addressForm.Street1"
                       placeholder="123 Main Street"
                       style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                          border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                          font-size:14px;color:#1E2A47;outline:none" />
            </div>

            <!-- Street 2 -->
            <div>
                <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                           text-transform:uppercase;letter-spacing:0.5px">
                    Apt, Suite, etc (optional)
                </label>
                <input @bind="addressForm.Street2"
                       placeholder="Apt 4B"
                       style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                          border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                          font-size:14px;color:#1E2A47;outline:none" />
            </div>

            <!-- City + State -->
            <div class="row g-2">
                <div class="col-7">
                    <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                               text-transform:uppercase;letter-spacing:0.5px">
                        City *
                    </label>
                    <input @bind="addressForm.City"
                           placeholder="New York"
                           style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                              border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                              font-size:14px;color:#1E2A47;outline:none" />
                </div>
                <div class="col-5">
                    <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                               text-transform:uppercase;letter-spacing:0.5px">
                        State
                    </label>
                    <input @bind="addressForm.State"
                           placeholder="NY"
                           style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                              border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                              font-size:14px;color:#1E2A47;outline:none" />
                </div>
            </div>

            <!-- Postal Code + Country -->
            <div class="row g-2">
                <div class="col-6">
                    <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                               text-transform:uppercase;letter-spacing:0.5px">
                        Postal Code *
                    </label>
                    <input @bind="addressForm.PostalCode"
                           placeholder="10001"
                           style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                              border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                              font-size:14px;color:#1E2A47;outline:none" />
                </div>
                <div class="col-6">
                    <label style="color:#1E2A47;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                                                               text-transform:uppercase;letter-spacing:0.5px">
                        Country
                    </label>
                    <input @bind="addressForm.Country"
                           placeholder="US"
                           style="width:100%;margin-top:4px;padding:10px 12px;
                                                                                                                                                                                                                                                                                              border:1px solid rgba(169,183,204,0.6);
                                                                                                                                                                                                                                                                                              font-size:14px;color:#1E2A47;outline:none" />
                </div>
            </div>

            <!-- Set as Default -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="isDefault"
                       @bind="addressForm.IsDefault"
                       style="width:16px;height:16px;accent-color:#1E2A47" />
                <label for="isDefault"
                       style="color:#1E2A47;font-size:14px;margin:0;cursor:pointer">
                    Set as default address
                </label>
            </div>

        </div>

        <!-- SAVE BUTTON -->
        <button @onclick="HandleSaveAddress"
                disabled="@isSavingAddress"
                style="width:100%;margin-top:32px;padding:14px;
                                                                                                                                                                                                                                                                                   background:#1E2A47;color:white;border:none;
                                                                                                                                                                                                                                                                                   font-size:14px;font-weight:700;
                                                                                                                                                                                                                                                                                   text-transform:uppercase;letter-spacing:0.5px;
                                                                                                                                                                                                                                                                                   opacity:@(isSavingAddress ? "0.7" : "1")">
            @(isSavingAddress ? "Saving..." : (isEditMode ? "Save Changes" : "Add Address"))
        </button>

    </div>
}



