@page "/login"
@layout Layout.AuthLayout.AuthLayout
@using Microsoft.AspNetCore.Components.Authorization
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Application.Services.CartService
@using MuuqWear.Application.Shared
@rendermode InteractiveServer
@using MuuqWear.Model.Authentication
@inject IAuthService IAuthService
@inject IJSRuntime JS
@inject AuthStateService AuthStateService
@inject NavigationManager NavigationManager

<section class="mw-auth">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-6 col-lg-4 mt-5">
                <div class="mw-auth-card text-center">
                    <a href="/">
                        <img src="/images/muuqwearlogo.png" class="mw-auth-logo mb-3" />
                    </a>
                    <h2 class="mw-auth-title">Welcome Back</h2>
                    <p class="mw-auth-subtitle mb-4">Sign in to your account</p>

                    <!-- TABS -->
                    <div class="mw-auth-tabs mb-4">
                        <button class="mw-auth-tab @(activeTab == "password" ? "active" : "")"
                                @onclick='() => SwitchTab("password")'>
                            Password
                        </button>
                        <button class="mw-auth-tab @(activeTab == "magic" ? "active" : "")"
                                @onclick='() => SwitchTab("magic")'>
                            Magic Link
                        </button>
                    </div>

                    <!-- PASSWORD TAB -->
                    @if (activeTab == "password")
                    {
                        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <InputText class="form-control mw-input"
                                           placeholder="Email"
                                           @bind-Value="loginModel.Email" />
                                <ValidationMessage For="@(() => loginModel.Email)" />
                            </div>

                            <div class="mb-3">
                                <InputText class="form-control mw-input"
                                           placeholder="Password"
                                           type="password"
                                           @bind-Value="loginModel.Password" />
                                <ValidationMessage For="@(() => loginModel.Password)" />
                            </div>
                            <div class="d-flex justify-content-end mb-3">
                                <a href="/forgot-password" class="mw-forgot-link">
                                    Forgot password?
                                </a>
                            </div>
                            <!-- REMEMBER ME -->
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="form-check text-start">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           id="rememberMe"
                                           @bind="rememberMe" />
                                    <label class="form-check-label small" for="rememberMe">
                                        Remember Me
                                    </label>
                                </div>
                            </div>

                            <button type="submit" class="mw-btn-primary w-100">
                                Login
                            </button>

                            @if (!string.IsNullOrEmpty(message))
                            {
                                <div class="@messageCssClass mt-2">
                                    <span>@message</span>
                                </div>
                            }

                        </EditForm>
                    }

                    <!-- MAGIC LINK TAB -->
                    <!-- MAGIC LINK TAB -->
                    @if (activeTab == "magic")
                    {
                        <div class="mw-magic-link">

                            <p class="mw-auth-subtitle mb-4">
                                No password needed. Enter your email
                                and we'll send you a secure login link.
                            </p>

                            <div class="mb-4">
                                <input class="form-control mw-input w-100"
                                       placeholder="Enter your email address"
                                       @bind="magicLinkEmail"
                                       @bind:event="oninput" />
                            </div>

                            <button type="button"
                                    class="mw-btn-primary w-100"
                                    @onclick="HandleMagicLink"
                                    disabled="@isSendingMagicLink">
                                @if (isSendingMagicLink)
                                {
                                    <span class="mw-btn-spinner"></span>
                                    <span>Sending link...</span>
                                }
                                else
                                {
                                    <span>Send Magic Link</span>
                                }
                            </button>

                            @if (!string.IsNullOrEmpty(magicLinkMessage))
                            {
                                <div class="mt-3 p-3 rounded @(magicLinkMessageCss == "text-success" ? "mw-alert-success" : "mw-alert-error")">
                                    <span>@magicLinkMessage</span>
                                </div>
                            }

                        </div>
                    }
                    <!-- DIVIDER -->
                    <div class="mw-auth-divider my-3">
                        <span>or continue with</span>
                    </div>

                    <!-- SOCIAL BUTTONS -->
                    <div class="mw-social-buttons">

                        <!-- GOOGLE -->
                        <button type="button"
                                class="mw-social-btn"
                                @onclick="HandleGoogleSignIn"
                                disabled="@isGoogleLoading">
                            @if (isGoogleLoading)
                            {
                                <span class="mw-btn-spinner" style="border-top-color: #4285F4"></span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
                                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                                </svg>
                            }
                            <span>Google</span>
                        </button>

                        <!-- APPLE -->
                        <button type="button" class="mw-social-btn" disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 814 1000">
                                <path fill="#000" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-36.8-162.1-105.3C110.3 714.4 68 639 33.3 556.2c-35-85.1-50.9-168.2-50.9-248.3 0-141.9 93.1-275.7 236.3-275.7 80.5 0 138.9 52.7 185.2 52.7 43.2 0 111.6-55.5 202.8-55.5 37.8 0 161.2 3.5 237.9 137zM460.9 161.3c22-26.7 38.1-64.2 38.1-101.7 0-5.2-.5-10.5-1.5-15.1-35.8 1.4-78.5 23.9-104.2 54.3-20 22.7-38.9 60.2-38.9 98.2 0 5.8 1 11.5 1.5 13.3 2.3.4 6 .9 9.7.9 32.1 0 72.5-21.5 95.3-49.9z" />
                            </svg>
                            <span>Apple</span>
                        </button>

                    </div>

                    <!-- REGISTER LINK -->
                    <p class="text-center mt-4 small">
                        Don't have an account?
                        <a href="/register" class="mw-link">Create one</a>
                    </p>

                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private bool isGoogleLoading = false;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [Inject]
    public CartStateService CartStateService { get; set; } = default!;

    private string activeTab = "password"; // default tab

    private LoginModel loginModel = new();
    private string message = "";
    private string messageCssClass = "";
    private bool rememberMe = false;

    private string magicLinkEmail = string.Empty;
    private bool isSendingMagicLink = false;
    private string magicLinkMessage = string.Empty;
    private string magicLinkMessageCss = string.Empty;

    private void SwitchTab(string tab)
    {
        activeTab = tab;

        // reset messages when switching tabs
        message = string.Empty;
        messageCssClass = string.Empty;
        magicLinkMessage = string.Empty;
        magicLinkMessageCss = string.Empty;
    }

    private async Task HandleLogin()
    {
        var result = await IAuthService.Login(loginModel);

        if (result.Success && result.Data != null)
        {
            var authData = result.Data;
            if (authData.Role != "user")
            {
                message = "Access denied.";
                messageCssClass = "text-danger";
                return;
            }

            await AuthNavigationHelper.PrepareAndNavigateAsync(
                result.Data,
                NavigationManager,
                "/profile",
                rememberMe);
        }
        else
        {
            message = result.Message;
            messageCssClass = "text-danger";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null) return;
        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/profile", replace: true);
        }
    }

    private async Task HandleMagicLink()
    {
        if (string.IsNullOrWhiteSpace(magicLinkEmail))
        {
            magicLinkMessage = "Please enter your email";
            magicLinkMessageCss = "text-danger";
            return;
        }
        if (!MuuqWearUtils.IsValidEmail(magicLinkEmail))
        {
            magicLinkMessage = "Please enter a valid email address";
            magicLinkMessageCss = "text-danger";
            return;
        }

        isSendingMagicLink = true;
        magicLinkMessage = string.Empty;
        StateHasChanged();

        var result = await IAuthService.SendMagicLink(
            new MagicLinkModel { Email = magicLinkEmail });

        if (result.Success)
        {
            magicLinkMessage = result.Message;
            magicLinkMessageCss = "text-success";
        }
        else
        {
            magicLinkMessage = result.Message;
            magicLinkMessageCss = "text-danger";
        }

        isSendingMagicLink = false;
    }

    private async Task HandleGoogleSignIn()
    {
        try
        {
            isGoogleLoading = true;
            StateHasChanged();

            // get Google OAuth URL from backend
            var result = await IAuthService.GetGoogleSignInUrl();

            if (result.Success && !string.IsNullOrEmpty(result.Data))
            {
                // navigate to Google OAuth URL
                // forceLoad: true → full page redirect
                // needed for OAuth flow
                NavigationManager.NavigateTo(result.Data, forceLoad: true);
            }
            else
            {
                message = result.Message ?? "Failed to connect to Google";
                messageCssClass = "text-danger";
                isGoogleLoading = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            message = "Something went wrong. Please try again.";
            messageCssClass = "text-danger";
            isGoogleLoading = false;
            Console.WriteLine(ex.Message);
            StateHasChanged();
        }
    }
}