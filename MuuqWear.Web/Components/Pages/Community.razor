@page "/community"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Community</PageTitle>

<!-- VoteSection-->
<section class="mw-vote">
    <div class="mw-vote__container">

        <!-- Content -->
        <div class="mw-vote__content">
            <h1 class="mw-vote__title">
                You Vote. We Make.
            </h1>

            <p class="mw-vote__description">
                Browse upcoming designs, vote for your favorites, pick the winning colors,
                and be the first to secure your pre-order.
            </p>
        </div>

        <!-- Image -->
        <div class="mw-vote__image-wrapper">
            <img src="https://images.unsplash.com/photo-1762232975039-7b36432bcac6?w=500&h=400&fit=crop"
                 alt="Vote hero"
                 class="mw-vote__image" />
        </div>

    </div>
</section>
<!-- End VoteSection-->
<!-- How it Works Section-->
<section class="mw-how">
    <div class="mw-how__container">

        <!-- Title -->
        <h2 class="mw-how__title">
            How it Works
        </h2>

        <!-- Steps -->
        <div class="mw-how__steps">

            <!-- Step 1 -->
            <div class="mw-how__step">
                <div class="mw-how__step-number">1</div>
                <h3 class="mw-how__step-title">Vote for Designs</h3>
                <p class="mw-how__step-desc">
                    Browse our latest concepts and vote for the styles and colors
                    you want to see in production.
                </p>
            </div>

            <!-- Step 2 -->
            <div class="mw-how__step">
                <div class="mw-how__step-number">2</div>
                <h3 class="mw-how__step-title">We Make the Winners</h3>
                <p class="mw-how__step-desc">
                    The most popular designs move into production using our
                    sustainable manufacturing process.
                </p>
            </div>

            <!-- Step 3 -->
            <div class="mw-how__step">
                <div class="mw-how__step-number">3</div>
                <h3 class="mw-how__step-title">Secure Your Pre-Order</h3>
                <p class="mw-how__step-desc">
                    Be the first to own the winning looks by securing your
                    pre-order at a special community price.
                </p>
            </div>

        </div>

        <!-- Stats Bar -->
        <div class="mw-how__stats">

            <div class="mw-how__stat">
                <svg class="mw-how__icon" viewBox="0 0 24 24">
                    <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
                <span class="mw-how__stat-strong">1,284</span>
                <span class="mw-how__stat-text">votes cast this week</span>
            </div>

            <div class="mw-how__stat">
                <svg class="mw-how__icon" viewBox="0 0 24 24">
                    <path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"></path>
                    <circle cx="12" cy="8" r="6"></circle>
                </svg>
                <span class="mw-how__stat-text">
                    Most wanted color: Sapphire Dust
                </span>
            </div>

            <div class="mw-how__stat">
                <svg class="mw-how__icon" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <span class="mw-how__stat-text">
                    Hoodie vote ends in 2 days
                </span>
            </div>

        </div>

    </div>
</section>

<!-- Trending Vote Now Section-->

<section class="mw-carousel">
    <div class="container">

        <!-- Header -->
        <div class="mw-carousel__header">

            <div class="mw-carousel__tabs">
                <button class="mw-carousel__tab mw-carousel__tab--active">Upcoming Designs</button>
                <button class="mw-carousel__tab">Latest Concepts</button>
                <button class="mw-carousel__tab">Top Voted</button>
                <button class="mw-carousel__tab">Pre-Order Ready</button>
            </div>

            <div class="mw-carousel_nav">
                <button @onclick="() => ScrollLeft(trendingRef)" class="d-flex align-items-center">
                    <!-- LEFT -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
                <button @onclick="() => ScrollRight(trendingRef)" class="d-flex align-items-center">
                    <!-- RIGHT -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                    </svg>

                </button>
            </div>

        </div>

        <!-- Carousel -->
        <div class="mw-carousel__track" @ref="trendingRef">

            <div class="row flex-nowrap gx-3 overflow-hidden">

                @foreach (var item in Items)
                {
                    <div class="col-12 col-sm-6 col-md-6 col-lg-4 mw-carousel-item">

                        <div class="mw-card">

                            <div class="mw-card__image-wrapper">
                                <img src="@item.Image" class="mw-card__image" />

                                @if (!string.IsNullOrEmpty(item.Tag))
                                {
                                    <span class="mw-card__badge">@item.Tag</span>
                                }
                            </div>

                            <div class="mw-card__content">
                                <h3 class="mw-card__title">@item.Title</h3>
                                <p class="mw-card__subtitle">@item.Subtitle</p>

                                <div class="mw-card__votes">
                                    👍 <strong>@item.Votes</strong> votes
                                </div>

                                <div class="mw-card__colors">
                                    @foreach (var color in item.Colors)
                                    {
                                        <span class="mw-card__color" style="background:@color"></span>
                                    }
                                </div>

                                <button class="mw-card__primary">Vote Now</button>
                                <button class="mw-card__secondary">Pre-Order this Look</button>
                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>
</section>
<!-- How it Works Section End-->
<!-- Recently Finished Section-->

<section class="mw-finished">
    <div class="container">

        <!-- Header -->
        <div class="mw-finished__header d-flex justify-content-between align-items-center">
            <h2 class="mw-finished__title">Recently Finished</h2>

            <div class="mw-carousel_nav d-flex gap-2">
                <button @onclick="() => ScrollLeft(finishedRef)">‹</button>
                <button @onclick="() => ScrollRight(finishedRef)">›</button>
            </div>
        </div>

        <p class="mw-finished__desc">
            These community-favorites reached their vote goals and are now in production.
        </p>

        <!-- Carousel -->
        <div class="mw-carousel__track" @ref="finishedRef">

            <div class="row flex-nowrap gx-3">

                @foreach (var item in FinishedItems)
                {
                    <div class="col-12 col-sm-6 col-md-6 col-lg-4 mw-carousel-item">

                        <div class="mw-finished-card">

                            <div class="mw-finished-card__image-wrapper">
                                <img src="@item.Image" class="mw-finished-card__image" />

                                <span class="mw-finished-card__badge @item.BadgeClass">
                                    @item.Badge
                                </span>
                            </div>

                            <div class="mw-finished-card__content">
                                <h3 class="mw-finished-card__title">@item.Title</h3>
                                <p class="mw-finished-card__subtitle">@item.Subtitle</p>

                                <button class="mw-card__primary">
                                    Shop Now
                                </button>
                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>
</section>
<!-- End of Recently Finished Section -->
