    protected override async Task OnInitializedAsync()
    {
        await LoadTickets();
    }

    private async Task LoadTickets()
    {
        isTicketsLoading = true;

        var filter = new ProductFilterModel
        {
            Page = 1,
            PageSize = 100,
            IncludeTickets = true
        };

        var result = await ProductService.GetAll(filter);

        if (result.Success && result.Data?.Data != null)
        {
            var ticketIds = TicketTiers.Select(t => t.ProductId).ToHashSet();
            ticketProducts = result.Data.Data
                .Where(p => ticketIds.Contains(p.Id))
                .ToDictionary(p => p.Id);
        }

        isTicketsLoading = false;
        StateHasChanged();   // ← force re-render
    }


    private async Task HandleTicketPurchase(TicketTier tier, ProductModel product)
    {
        processingTicketId = tier.ProductId;
        addToCartMessage = string.Empty;
        lastMessageTicketId = null;
        StateHasChanged();

        var success = await CartStateService.AddItem(new AddCartItemModel
        {
            ProductId = product.Id,
            Size = "One Size",
            Color = "Sapphire",
            Quantity = 1,
            ProductName = product.Name,
            ProductImageUrl = product.ImageUrl ?? "/images/muuqsimo-tickets.jpg",
            ProductPrice = product.Price
        });

        if (success)
        {
            addToCartMessage = "Added to bag! ✓";
            addToCartMessageCss = "text-success";
        }
        else
        {
            addToCartMessage = "Failed to add. Please try again.";
            addToCartMessageCss = "text-danger";
        }

        lastMessageTicketId = tier.ProductId;
        processingTicketId = null;
        StateHasChanged();

        // Clear message after 3 seconds, but only if it still belongs to this ticket
        await Task.Delay(3000);
        if (lastMessageTicketId == tier.ProductId)
        {
            addToCartMessage = string.Empty;
            lastMessageTicketId = null;
            StateHasChanged();
        }



    }


