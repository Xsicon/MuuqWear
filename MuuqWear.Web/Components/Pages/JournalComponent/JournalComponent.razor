@page "/journal"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IJournalService JournalService
@using MuuqWear.Application.Interfaces
@using MuuqWear.Application.Services.JournalService
@using MuuqWear.Model.ContentItem
@using MuuqWear.Web.Components.Shared

<PageTitle>Journal</PageTitle>

<!-- Journal Hero Section -->

<SpinnerComponent Show="@isLoading" />

<section class="mw-journal-hero">
    <div class="mw-journal-hero__container">
        @if (heroArticle != null)
        {
            <div class="mw-journal-hero__card">
                <div class="mw-journal-hero__content">
                    <p class="mw-journal-hero__category">@heroArticle.Category</p>
                    <h1 class="mw-journal-hero__title">@heroArticle.Title</h1>
                    <p class="mw-journal-hero__description">
                        @TruncateContent(heroArticle.Content, 150)
                    </p>
                    <span class="mw-journal-hero__cta"
                          @onclick="() => OpenArticle(heroArticle)">
                        Read More
                        <svg viewBox="0 0 24 24" class="mw-journal-hero__icon">
                            <path d="M5 12h14"></path>
                            <path d="m12 5 7 7-7 7"></path>
                        </svg>
                    </span>
                </div>
                <div class="mw-journal-hero__image-wrapper">
                    @if (!string.IsNullOrEmpty(heroArticle.ImageUrl))
                    {
                        <img src="@heroArticle.ImageUrl"
                             class="mw-journal-hero__image"
                             alt="@heroArticle.Title" />
                    }
                </div>
            </div>
        }
    </div>
</section>

<!-- Journal Filters Section -->
<section class="mw-journal-filters mb-3">
    <div class="mw-journal-hero__container">
        <div class="d-flex flex-nowrap gap-2 overflow-auto mw-tabs-scroll">
            <!-- filters -->
            <button class="mw-filter-tab @(activeFilter == "All" ? "active" : "")"
                    @onclick='() => SetFilter("All")'>
                All
            </button>
            @foreach (var category in categories)
            {
                <button class="mw-filter-tab @(activeFilter == category ? "active" : "")"
                        @onclick="() => SetFilter(category)">
                    @category
                </button>
            }


        </div>
    </div>
</section>

<!-- Journal Article Section-->
<section class="mw-articles pb-5">
    <div class="mw-journal-hero__container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mw-articles__title">Latest Articles</h2>
            <div class="mw-carousel_nav">
                <button @onclick="() => ScrollLeft(articleRef)"
                        class="d-flex align-items-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
                <button @onclick="() => ScrollRight(articleRef)"
                        class="d-flex align-items-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                    </svg>
                </button>
            </div>
        </div>

        <p style="color:#4A5C7A">Loading articles...</p>
        <div class="mw-carousel__track" @ref="articleRef">
            <div class="mw-carousel-inner">
                @foreach (var item in filteredArticles)
                {
                    <div class="mw-carousel-item">
                        <article class="mw-article-card d-flex">
                            <div class="mw-article-card__img">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Title" />
                                }
                            </div>
                            <div class="mw-article-card__content">
                                <p class="mw-article-card__category">@item.Category</p>
                                <h3 class="mw-article-card__title">@item.Title</h3>
                                <p class="mw-article-card__desc">
                                    @TruncateContent(item.Content, 100)
                                </p>
                                <span class="mw-article-card__link"
                                      @onclick="() => OpenArticle(item)">
                                    Read More →
                                </span>
                            </div>
                        </article>
                    </div>
                }
            </div>
        </div>
        <!--  only one, in the right place, with conditions -->
        @if (hasMore)
        {
            <div class="text-center mt-4">
                <button class="mw-articles__btn"
                        @onclick="LoadMore"
                        disabled="@isLoadingMore">
                    @(isLoadingMore ? "Loading..." : "Load More Articles")
                </button>
            </div>
        }

    </div>
</section>

<!-- ARTICLE DETAIL PANEL -->
@if (selectedArticle != null)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:60"
         @onclick="CloseArticle">
    </div>

    <div style="position:fixed;top:0;right:0;bottom:0;width:100%;
                                                                                            max-width:800px;background:white;z-index:61;
                                                                                            overflow-y:auto;box-shadow:-4px 0 24px rgba(0,0,0,0.15)">

        <!-- close button -->
        <button @onclick="CloseArticle"
                style="position:absolute;top:21px;right:21px;z-index:10;
                                                                                                   width:40px;height:40px;background:white;
                                                                                                   border:1px solid #A9B7CC;display:flex;
                                                                                                   align-items:center;justify-content:center;
                                                                                                   color:#1E2A47;cursor:pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18"></path>
                <path d="m6 6 12 12"></path>
            </svg>
        </button>

        <!-- image -->
        @if (!string.IsNullOrEmpty(selectedArticle.ImageUrl))
        {
            <div style="width:100%;height:350px;overflow:hidden;background:#E6ECF5">
                <img src="@selectedArticle.ImageUrl"
                     alt="@selectedArticle.Title"
                     style="width:100%;height:100%;object-fit:cover" />
            </div>
        }

        <!-- content -->
        <div style="padding:34px;max-width:618px;margin:0 auto">

            <p style="color:#4A5C7A;font-size:12px;letter-spacing:2px;
                                                                                                  text-transform:uppercase;font-weight:700;margin-bottom:13px">
                @selectedArticle.Category
            </p>

            <h2 style="color:#1E2A47;font-size:30px;font-weight:800;
                                                                                                   letter-spacing:-1px;line-height:1.2;margin-bottom:21px;
                                                                                                   font-family:'Manrope',sans-serif">
                @selectedArticle.Title
            </h2>

            <div style="color:#1E2A47;font-size:17px;line-height:30px;
                                                                                                    font-family:'Playfair Display',serif;white-space:pre-line">
                @selectedArticle.Content
            </div>

            <!-- social links -->
            <div style="margin-top:55px;padding-top:21px;
                                                                                                    border-top:1px solid #A9B7CC">
                <p style="color:#4A5C7A;font-size:14px;margin-bottom:13px">
                    Enjoyed the read? Follow us for more.
                </p>
                <div style="display:flex;justify-content:flex-end;gap:21px">
                    <a href="#" target="_blank" style="color:#1E2A47">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                        </svg>
                    </a>
                    <a href="#" target="_blank" style="color:#1E2A47">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                        </svg>
                    </a>
                    <a href="#" target="_blank" style="color:#1E2A47">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4l11.733 16h4.267l-11.733-16z"></path>
                            <path d="M4 20l6.768-6.768m2.46-2.46L20 4"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ElementReference articleRef;
    private List<ContentItemModel> articles = new();
    private List<string> categories = new();
    private string activeFilter = "All";
    private bool isLoading = true;
    private ContentItemModel? heroArticle = null;
    private ContentItemModel? selectedArticle = null;
    private bool isLoadingMore = false;
    private bool hasMore = false;
    private int currentPage = 1;
    private const int PageSize = 6;

    private List<ContentItemModel> filteredArticles => articles;

    protected override async Task OnInitializedAsync()
    {
        //  fetch hero — always latest article (page 1, size 1, no filter)
        var heroResult = await JournalService.GetPublished(1, 1);
        if (heroResult.Success && heroResult.Data?.Data.Any() == true)
            heroArticle = heroResult.Data.Data.First();

        //  fetch categories — get all to build filter tabs
        var allResult = await JournalService.GetPublished(1, 100);
        if (allResult.Success && allResult.Data != null)
            categories = allResult.Data.Data
                .Where(x => !string.IsNullOrEmpty(x.Category))
                .Select(x => x.Category!)
                .Distinct()
                .ToList();

        //  fetch first page of articles
        await LoadArticles(reset: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && articleRef.Id != null)
        {
            await JS.InvokeVoidAsync("mwStartAutoSlide",
                articleRef, ".mw-carousel-item", 3000);
        }
    }

    private async Task LoadArticles(bool reset = false)
    {
        if (reset)
        {
            currentPage = 1;
            articles = new();
        }

        isLoading = reset;
        StateHasChanged();

        var category = activeFilter == "All" ? null : activeFilter;
        var result = await JournalService.GetPublished(currentPage, PageSize, category);

        if (result.Success && result.Data != null)
        {
            articles.AddRange(result.Data.Data); // ← append, not replace
            hasMore = result.Data.HasMore;
        }

        isLoading = false;
        StateHasChanged();
    }

    private async Task SetFilter(string filter)
    {
        activeFilter = filter;
        await LoadArticles(reset: true); // ← reset to page 1 on filter change
    }

    //  single responsibility — only loads next page
    private async Task LoadMore()
    {
        if (!hasMore || isLoadingMore) return;

        isLoadingMore = true;
        currentPage++;
        StateHasChanged();

        await LoadArticles();

        isLoadingMore = false;
        StateHasChanged();
    }

    private void OpenArticle(ContentItemModel article)
    {
        selectedArticle = article;
        StateHasChanged();
    }

    private void CloseArticle()
    {
        selectedArticle = null;
        StateHasChanged();
    }

    private async Task ScrollRight(ElementReference el)
    {
        await JS.InvokeVoidAsync("mwScrollRight", el, ".mw-carousel-item");
    }

    private async Task ScrollLeft(ElementReference el)
    {
        await JS.InvokeVoidAsync("mwScrollLeft", el, ".mw-carousel-item");
    }

    private string TruncateContent(string? content, int maxLength)
    {
        if (string.IsNullOrEmpty(content)) return string.Empty;
        return content.Length > maxLength
            ? content[..maxLength] + "..."
            : content;
    }
}