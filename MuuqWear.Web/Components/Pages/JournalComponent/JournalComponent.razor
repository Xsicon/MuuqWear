@page "/journal"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IJournalService JournalService
@using MuuqWear.Application.Interfaces
@using MuuqWear.Application.Services.JournalService
@using MuuqWear.Model.ContentItem

<PageTitle>Journal</PageTitle>

<!-- Journal Hero Section -->

<section class="mw-journal-hero">
    <div class="mw-journal-hero__container">
        @if (isLoading && heroArticle == null)
        {
            <div class="mw-journal-hero__card mw-journal-hero__card--loading"></div>
        }
        else if (heroArticle != null)
        {
            <div class="mw-journal-hero__card" @onclick="() => OpenArticleAsync(heroArticle)">
                <div class="mw-journal-hero__content">
                    <p class="mw-journal-hero__category">@heroArticle.Category</p>
                    <h1 class="mw-journal-hero__title">@heroArticle.Title</h1>
                    <p class="mw-journal-hero__description">
                        @TruncateContent(heroArticle.Content, 150)
                    </p>
                    <span class="mw-journal-hero__cta">
                        Read More
                        <svg viewBox="0 0 24 24" class="mw-journal-hero__icon">
                            <path d="M5 12h14"></path>
                            <path d="m12 5 7 7-7 7"></path>
                        </svg>
                    </span>
                </div>
                <div class="mw-journal-hero__image-wrapper">
                    @if (!string.IsNullOrEmpty(heroArticle.ImageUrl))
                    {
                        <img src="@heroArticle.ImageUrl"
                             class="mw-journal-hero__image"
                             alt="@heroArticle.Title" />
                    }
                </div>
            </div>
        }
    </div>
</section>

<!-- Journal Filters Section -->
<section class="mw-journal-filters mb-3">
    <div class="mw-journal-hero__container">
        <div class="mw-journal-filters__row">
            <!-- filters -->
            <button class="mw-filter-tab @(activeFilter == "All" ? "active" : "")"
                    @onclick='() => SetFilter("All")'>
                All
            </button>
            @foreach (var category in categories)
            {
                <button class="mw-filter-tab @(activeFilter == category ? "active" : "")"
                        @onclick="() => SetFilter(category)">
                    @category
                </button>
            }


        </div>
    </div>
</section>

<!-- Journal Article Section-->
<section class="mw-articles pb-5">
    <div class="mw-journal-hero__container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mw-articles__title">Latest Articles</h2>
        </div>

        @if (isLoading && !filteredArticles.Any())
        {
            <div class="mw-articles-loading">Loading articles...</div>
        }
        else
        {
            <div class="mw-articles-grid">
                @foreach (var item in filteredArticles)
                {
                    <article class="mw-article-card d-flex" @onclick="() => OpenArticleAsync(item)">
                        <div class="mw-article-card__img">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title" />
                            }
                        </div>
                        <div class="mw-article-card__content">
                            <p class="mw-article-card__category">@item.Category</p>
                            <h3 class="mw-article-card__title">@item.Title</h3>
                            <p class="mw-article-card__desc">
                                @TruncateContent(item.Content, 100)
                            </p>
                            <span class="mw-article-card__link">
                                Read More →
                            </span>
                        </div>
                    </article>
                }
            </div>
        }
        <!--  only one, in the right place, with conditions -->
        @if (hasMore)
        {
            <div class="text-center mt-4">
                <button class="mw-articles__btn"
                        @onclick="LoadMore"
                        disabled="@isLoadingMore">
                    @(isLoadingMore ? "Loading..." : "Load More Articles")
                </button>
            </div>
        }

    </div>
</section>

<!-- ARTICLE DETAIL PANEL -->
@if (selectedArticle != null)
{
    <div class="mw-journal-overlay" @onclick="CloseArticle"></div>

    <div class="mw-journal-panel" role="dialog" aria-modal="true" aria-label="Article">

        <button class="mw-journal-panel__close" @onclick="CloseArticle" aria-label="Close article">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18"></path>
                <path d="m6 6 12 12"></path>
            </svg>
        </button>

        @if (!string.IsNullOrEmpty(selectedArticle.ImageUrl))
        {
            <div class="mw-journal-panel__hero">
                <img src="@selectedArticle.ImageUrl" alt="@selectedArticle.Title" />
            </div>
        }

        <div class="mw-journal-panel__body">

            <p class="mw-journal-panel__category">@selectedArticle.Category</p>

            <h2 class="mw-journal-panel__title">@selectedArticle.Title</h2>

            <p class="mw-journal-panel__excerpt">@TruncateContent(selectedArticle.Content, 180)</p>

            <div class="mw-journal-panel__content">@selectedArticle.Content</div>

            <div class="mw-journal-panel__social">
                <p>Enjoyed the read? Follow us for more.</p>
                <div class="mw-journal-panel__social-links">
                    <a href="#" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                        </svg>
                    </a>
                    <a href="#" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                        </svg>
                    </a>
                    <a href="#" target="_blank" rel="noopener noreferrer" aria-label="X">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4l11.733 16h4.267l-11.733-16z"></path>
                            <path d="M4 20l6.768-6.768m2.46-2.46L20 4"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ContentItemModel> articles = new();
    private List<string> categories = new();
    private string activeFilter = "All";
    private bool isLoading = true;
    private ContentItemModel? heroArticle = null;
    private ContentItemModel? selectedArticle = null;
    private bool isLoadingMore = false;
    private bool hasMore = false;
    private int currentPage = 1;
    private const int PageSize = 6;

    private List<ContentItemModel> filteredArticles => articles;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        var result = await JournalService.GetPublished(1, PageSize);

        if (result.Success && result.Data != null)
        {
            var items = result.Data.Data;

            if (items.Any())
            {
                heroArticle = items.First();
                articles = items.Skip(1).ToList();
            }

            hasMore = result.Data.HasMore;
            MergeCategories(items);
        }

        isLoading = false;
    }

    private async Task LoadArticles(bool reset = false)
    {
        if (reset)
        {
            currentPage = 1;
            articles = new();
        }

        isLoading = reset;
        StateHasChanged();

        var category = activeFilter == "All" ? null : activeFilter;
        var result = await JournalService.GetPublished(currentPage, PageSize, category);

        if (result.Success && result.Data != null)
        {
            articles.AddRange(result.Data.Data);
            hasMore = result.Data.HasMore;
            MergeCategories(result.Data.Data);
        }

        isLoading = false;
        StateHasChanged();
    }

    private void MergeCategories(IEnumerable<ContentItemModel> items)
    {
        var merged = categories.ToList();

        foreach (var item in items)
        {
            if (!string.IsNullOrEmpty(item.Category) && !merged.Contains(item.Category))
                merged.Add(item.Category);
        }

        categories = merged.OrderBy(c => c).ToList();
    }

    private async Task SetFilter(string filter)
    {
        activeFilter = filter;
        await LoadArticles(reset: true); // ← reset to page 1 on filter change
    }

    //  single responsibility — only loads next page
    private async Task LoadMore()
    {
        if (!hasMore || isLoadingMore) return;

        isLoadingMore = true;
        currentPage++;
        StateHasChanged();

        await LoadArticles();

        isLoadingMore = false;
        StateHasChanged();
    }

    private async Task OpenArticleAsync(ContentItemModel article)
    {
        // The paged list endpoint does not include full Content.
        // Fetch the full article body when opening the panel.
        var full = await JournalService.GetById(article.Id);
        selectedArticle = full.Success && full.Data != null ? full.Data : article;

        _ = JS.InvokeVoidAsync("mwSetBodyOverflowHidden");
        await InvokeAsync(StateHasChanged);
    }

    private void CloseArticle()
    {
        selectedArticle = null;
        _ = JS.InvokeVoidAsync("mwClearBodyOverflow");
        StateHasChanged();
    }

    private string TruncateContent(string? content, int maxLength)
    {
        if (string.IsNullOrEmpty(content)) return string.Empty;
        return content.Length > maxLength
            ? content[..maxLength] + "..."
            : content;
    }
}