@page "/profile"
@page "/settings"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using MuuqWear.Application.Interfaces
@using MuuqWear.Application.Services.AffiliateService
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Application.Services.CartService
@using MuuqWear.Application.Services.WishlistService
@using MuuqWear.Application.Services.OrderService
@using MuuqWear.Application.Shared
@using MuuqWear.Model.Authentication
@using Microsoft.AspNetCore.Components.Authorization
@using MuuqWear.Model.Orders
@inject IOrderService OrderService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject IAuthService IAuthService
@inject NavigationManager NavigationManager
@inject CartStateService CartStateService
@attribute [Authorize(Roles = "user")]
@using MuuqWear.Model.Address
@using MuuqWear.Application.Services.AddressService
@inject IAddressService AddressService
@using MuuqWear.Model.Profile
@using MuuqWear.Application.Services.ProfileService
@inject IProfileService ProfileService
@using System.Net.Http
@using System.Net.Http.Json
@using MuuqWear.Web.Components.Pages.MileStoneComponent
@using MuuqWear.Web.Components.Pages.OrderConfirmedComponent
@using MuuqWear.Web.Components.Pages.PartnerStoreComponent
@using MuuqWear.Web.Components.Shared
@inject IHttpClientFactory HttpClientFactory
@inject AuthSessionService AuthSession
@inject IAffiliateService AffiliateService
@inject IJSRuntime JSRuntime
@inject WishlistStateService WishlistStateService
@implements IDisposable


<PageTitle>Profile</PageTitle>

<section class="mw-profile container py-4 py-md-5">

    <!-- MOBILE HEADER -->
    <div class="d-md-none mb-3">
        <button class="mw-profile-mobile-toggle"
                @onclick="() => isMobileMenuOpen = !isMobileMenuOpen">
            <span class="mw-profile-mobile-toggle__label">
                @Lucide(GetTabIconName(activeTab), 18)
                <span>@GetActiveTabLabel()</span>
            </span>
            <span class="mw-profile-mobile-toggle__chevron @(isMobileMenuOpen ? "is-open" : "")">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m9 18 6-6-6-6"></path>
                </svg>
            </span>
        </button>
    </div>


    @if (isMobileMenuOpen)
    {
        <div class="mw-mobile-menu d-md-none mb-3">

            <!-- USER INFO -->
            <div class="mw-mobile-menu__user">
                <div class="mw-avatar">SA</div>
                <div>
                    <h6 class="mw-user-name">@LoggedInUserName</h6>
                    <p class="mw-user-meta">Member since October 2024</p>
                </div>
            </div>

            <!-- NAV ITEMS -->
            <nav class="mw-mobile-menu__nav">
                <button class="mw-mobile-nav-item @(activeTab == "overview" ? "active" : "")"
                        @onclick='() => SelectTab("overview")'>
                    @Lucide("dashboard")
                    <span>Overview</span>
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "orders" ? "active" : "")"
                        @onclick='() => SelectTab("orders")'>
                    @Lucide("package")
                    <span>Orders</span>
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "wishlist" ? "active" : "")"
                        @onclick='() => SelectTab("wishlist")'>
                    @Lucide("heart")
                    <span>Wishlist</span>
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "addresses" ? "active" : "")"
                        @onclick='() => SelectTab("addresses")'>
                    @Lucide("mappin")
                    <span>Addresses</span>
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "affiliate" ? "active" : "")"
                        @onclick='() => SelectTab("affiliate")'>
                    @Lucide("users")
                    <span>Affiliate Hub</span>
                </button>
                <button class="mw-mobile-nav-item @(activeTab == "settings" ? "active" : "")"
                        @onclick='() => SelectTab("settings")'>
                    @Lucide("settings")
                    <span>Settings</span>
                </button>
            </nav>

            <!-- AFFILIATE STATUS -->
            <div class="mw-mobile-menu__affiliate">
                <p class="mw-affiliate-label">Affiliate Status</p>
                <p class="mw-affiliate-value">
                    <span class="mw-affiliate-star">@Lucide("star", 14)</span>
                    @(affiliateStatus?.Tier is { Length: > 0 } tier
                        ? char.ToUpper(tier[0]) + tier[1..]
                        : "Silver")
                </p>
            </div>

            <!-- SIGN OUT -->
            <button class="mw-mobile-menu__signout" @onclick="HandleSignOut">
                <span>Sign Out</span>
                @Lucide("logout")
            </button>

        </div>
    }



    <div class="row g-4">

        <!-- SIDEBAR -->
        <aside class="col-md-4 col-lg-3 d-none d-md-block">

            <!-- USER INFO -->
            <div class="mw-profile-user text-md-end">
                <div class="mw-avatar">SA</div>
                <h6 class="mw-user-name">@LoggedInUserName</h6>
                <p class="mw-user-meta">Member since October 2024</p>
            </div>

            <!-- NAV -->
            <nav class="mw-profile-nav">
                <button class="mw-nav-item @(activeTab == "overview" ? "active" : "")"
                        @onclick='() => activeTab = "overview"'>
                    <span>Overview</span>
                    @Lucide("dashboard")
                </button>
                <button class="mw-nav-item @(activeTab == "orders" ? "active" : "")"
                        @onclick='() => activeTab = "orders"'>
                    <span>Orders</span>
                    @Lucide("package")
                </button>
                <button class="mw-nav-item @(activeTab == "wishlist" ? "active" : "")"
                        @onclick='() => SelectTab("wishlist")'>
                    <span>Wishlist</span>
                    @Lucide("heart")
                </button>
                <button class="mw-nav-item @(activeTab == "addresses" ? "active" : "")"
                        @onclick='() => activeTab = "addresses"'>
                    <span>Addresses</span>
                    @Lucide("mappin")
                </button>
                <button class="mw-nav-item @(activeTab == "affiliate" ? "active" : "")"
                        @onclick='() => SelectTab("affiliate")'>
                    <span>Affiliate Hub</span>
                    @Lucide("users")
                </button>
                <button class="mw-nav-item @(activeTab == "settings" ? "active" : "")"
                        @onclick='() => SelectTab("settings")'>
                    <span>Settings</span>
                    @Lucide("settings")
                </button>
            </nav>

            <!-- AFFILIATE -->
            <!-- AFFILIATE STATUS -->
            @if (affiliateStatus != null)
            {
                <div class="mw-affiliate">
                    <p class="mw-affiliate-label">Affiliate Status</p>

                    @if (affiliateStatus.ApplicationStatus == "not_applied")
                    {
                        <p class="mw-affiliate-value mw-affiliate-not-applied">
                            Not Applied
                        </p>
                    }
                    else if (affiliateStatus.ApplicationStatus == "pending")
                    {
                        <p class="mw-affiliate-value mw-affiliate-pending">
                            ⏳ Pending
                        </p>
                    }
                    else if (affiliateStatus.ApplicationStatus == "approved")
                    {
                        @if (affiliateStatus.Tier == "bronze")
                        {
                            <p class="mw-affiliate-value mw-affiliate-bronze">
                                🥉 Bronze
                            </p>
                        }
                        else if (affiliateStatus.Tier == "silver")
                        {
                            <p class="mw-affiliate-value mw-affiliate-silver">
                                ⭐ Silver
                            </p>
                        }
                        else if (affiliateStatus.Tier == "gold")
                        {
                            <p class="mw-affiliate-value mw-affiliate-gold">
                                ⭐⭐ Gold
                            </p>
                        }
                    }
                    else if (affiliateStatus.ApplicationStatus == "rejected")
                    {
                        <p class="mw-affiliate-value mw-affiliate-rejected">
                             Rejected
                        </p>
                    }
                    else if (affiliateStatus.ApplicationStatus == "waitlisted")
                    {
                        <p class="mw-affiliate-value mw-affiliate-waitlisted">
                            📋 Waitlisted
                        </p>
                    }
                </div>
            }
            else
            {
                <!-- Loading state -->
                <div class="mw-affiliate">
                    <p class="mw-affiliate-label">Affiliate Status</p>
                    <p class="mw-affiliate-value">Loading...</p>
                </div>
            }

            <!-- SIGN OUT -->
            <button class="mw-signout" @onclick="HandleSignOut">
                <span>Sign Out</span>
                @Lucide("logout")
            </button>

        </aside>

        <!-- MAIN CONTENT -->
        <!-- MAIN CONTENT -->
        <div class="col-12 col-md-8 col-lg-9">

            <!-- WELCOME — always visible -->
            @if (activeTab == "overview")
            {
                <div class="mb-4">
                    <h2 class="mw-welcome">Welcome back, @LoggedInUserName</h2>
                    <p class="mw-subtext">Here's your Muuqwear at a glance.</p>
                </div>

                <!-- STATS -->
                <div class="row g-3 mb-4">
                    <!-- ... your stat cards ... -->
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <span class="mw-stat-icon">@Lucide("package", 18)</span>
                            <p class="mw-stat-value">@userOrders.Count</p>
                            <p class="mw-stat-label">Orders</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <span class="mw-stat-icon">@Lucide("heart", 18)</span>
                            <p class="mw-stat-value">@WishlistStateService.Count</p>
                            <p class="mw-stat-label">Wishlist</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <span class="mw-stat-icon">@Lucide("star", 18)</span>
                            <p class="mw-stat-value">@affiliateStatus?.Tier</p>
                            <p class="mw-stat-label">Affiliate Tier</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mw-stat-card">
                            <span class="mw-stat-icon">@Lucide("dashboard", 18)</span>
                            <p class="mw-stat-value">$1251</p>
                            <p class="mw-stat-label">Total Spent</p>
                        </div>
                    </div>
                </div>

                <!-- RECENT ORDERS -->
                <div class="mw-orders">
                    <p class="mw-section-title">Recent Orders</p>
                    <OrdersList Orders="userOrders.Take(3).ToList()" />
                </div>
            }
            else if (activeTab == "orders")
            {
                <div class="mw-orders">
                    <p class="mw-section-title">All Orders</p>
                    <OrdersList Orders="userOrders" />
                </div>
            }
            else if (activeTab == "wishlist")
            {
                <div class="mw-wishlist-section">
                    <p class="mw-section-title">My Wishlist</p>

                    @if (!WishlistStateService.Items.Any())
                    {
                        <div class="mw-wishlist-empty">
                            <span class="mw-wishlist-empty__icon">@Lucide("heart", 40)</span>
                            <p>Your wishlist is empty.</p>
                            <a href="/shop/apparel" class="mw-wishlist-empty__link">Browse Products</a>
                        </div>
                    }
                    else
                    {
                        <div class="mw-wishlist-grid">
                            @foreach (var item in WishlistStateService.Items)
                            {
                                <article class="mw-wishlist-card">
                                    <div class="mw-wishlist-card__media">
                                        <a href="/productdetail/@item.ProductId">
                                            <img src="@item.ProductImageUrl" alt="@item.ProductName" loading="lazy" />
                                        </a>
                                        <WishlistButtonComponent ProductId="@item.ProductId"
                                                                 ProductName="@item.ProductName"
                                                                 ProductImageUrl="@item.ProductImageUrl"
                                                                 ProductPrice="@item.ProductPrice"
                                                                 CssClass="mw-wishlist-btn--overlay"
                                                                 Size="16" />
                                    </div>
                                    <div class="mw-wishlist-card__body">
                                        <a href="/productdetail/@item.ProductId" class="mw-wishlist-card__name">
                                            @item.ProductName
                                        </a>
                                        <p class="mw-wishlist-card__price">$@item.ProductPrice.ToString("F2")</p>
                                        <a href="/productdetail/@item.ProductId" class="mw-wishlist-card__view">
                                            View Product
                                        </a>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>
            }

            else if (activeTab == "addresses")
            {
                <!-- HEADER -->
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <p style="color:#1E2A47;font-size:24px;
                                                                                                                                                                                                                                                                                                                                                                                          font-family:'Playfair Display',serif;margin:0">
                        Saved Addresses
                    </p>
                    <button @onclick="OpenAddForm" style="display:flex;align-items:center;gap:6px;
                                                                                                                                                                                                                                                               border:1px solid #1E2A47;color:#1E2A47;
                                                                                                                                                                                                                                                               padding:8px 16px;font-size:12px;font-weight:700;
                                                                                                                                                                                                                                                               text-transform:uppercase;letter-spacing:0.5px;
                                                                                                                                                                                                                                                               background:transparent">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14"></path>
                            <path d="M12 5v14"></path>
                        </svg>
                        Add New
                    </button>
                </div>

                <!-- EMPTY STATE -->
                @if (!addresses.Any())
                {
                    <p style="color:#4A5C7A;font-size:14px">
                        No saved addresses yet. Add one to get started.
                    </p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var address in addresses)
                        {
                            <div class="col-12 col-md-6">
                                <div class="h-100"
                                     style="border:1px solid @(address.IsDefault ? "#1E2A47" : "rgba(169,183,204,0.4)");
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        padding:21px">

                                    <!-- header -->
                                    <div class="d-flex align-items-center
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            justify-content-between mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <p style="color:#1E2A47;font-size:14px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  font-weight:700;margin:0">
                                                @address.Label
                                            </p>
                                            @if (address.IsDefault)
                                            {
                                                <span style="font-size:10px;background:#1E2A47;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 color:white;padding:2px 8px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 text-transform:uppercase;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 font-weight:700;letter-spacing:0.5px">
                                                    Default
                                                </span>
                                            }
                                        </div>
                                        <button @onclick="() => EditAddress(address)"
                                                style="color:#4A5C7A;background:transparent;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   border:none;padding:0">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round"
                                                 stroke-linejoin="round">
                                                <path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"></path>
                                            </svg>
                                        </button>
                                    </div>

                                    <!-- address lines -->
                                    <p style="color:#4A5C7A;font-size:13px;margin:0">
                                        @address.FullName
                                    </p>
                                    <p style="color:#4A5C7A;font-size:13px;margin:0">
                                        @address.Street1
                                    </p>
                                    @if (!string.IsNullOrEmpty(address.Street2))
                                    {
                                        <p style="color:#4A5C7A;font-size:13px;margin:0">
                                            @address.Street2
                                        </p>
                                    }
                        <p style="color:#4A5C7A;font-size:13px;margin:0">
                            @address.City@(string.IsNullOrEmpty(address.State)
                                                        ? "" : $", {address.State}") @address.PostalCode
                        </p>

                                    <!-- set as default -->
                        @if (!address.IsDefault)
                                    {
                                        <button @onclick="() => HandleSetDefault(address.Id)"
                                                style="margin-top:10px;font-size:12px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           color:#1E2A47;font-weight:700;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           text-decoration:underline;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           background:transparent;border:none;padding:0">
                                            Set as Default
                                        </button>
                                    }

                                </div>
                            </div>
                        }
                    </div>
                }
            }

            else if (activeTab == "affiliate")
            {
                <div class="mw-tab-content">
                    @if (affiliateStatus == null)
                    {
                        <p>Loading affiliate status...</p>
                    }
                    else if (affiliateStatus.ApplicationStatus == "not_applied")
                    {
                        <!-- NOT APPLIED - Show Apply Prompt -->
                        <div class="affiliate-not-applied">
                            <h2>Join the MuuqWear Affiliate Program</h2>
                            <p>Earn commission on every sale you refer!</p>
                            <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo("/affiliate")'>
                                Apply Now
                            </button>
                        </div>
                    }
                    else if (affiliateStatus.ApplicationStatus == "pending")
                    {
                        <!-- PENDING REVIEW -->
                        <div class="affiliate-pending-review">
                            <div class="pending-icon">⏳</div>
                            <h2>Application Under Review</h2>
                            <p>Your affiliate application is being reviewed by our team.</p>
                            <p>We'll notify you via email once a decision has been made.</p>
                            @if (affiliateStatus.SubmittedAt.HasValue)
                            {
                                <p class="submitted-date">
                                    Submitted on @affiliateStatus.SubmittedAt.Value.ToString("MMMM dd, yyyy")
                                </p>
                            }
                            <div class="pending-next-steps">
                                <h4>What happens next?</h4>
                                <ul>
                                    <li>Our team reviews your application (usually within 2-3 business days)</li>
                                    <li>We'll check your social media presence and content quality</li>
                                    <li>You'll receive an email with the decision</li>
                                    <li>If approved, you'll get access to your affiliate dashboard</li>
                                </ul>
                            </div>
                        </div>
                    }
                 else if (affiliateStatus.ApplicationStatus == "approved")
{
    <div class="affiliate-dashboard-complete">

        <!-- 1. TOP HEADER (MUST BE HERE - OUTSIDE THE TAB IF BLOCKS) -->
        <div class="affiliate-dashboard-header">
          @*   <div class="header-left">
                <div class="user-avatar">
                    <span>@GetUserInitials()</span>
                </div>
                <div class="user-info">
                    <h2 class="user-name">@profile?.FullName</h2>
                    <p class="member-since">Member since @GetMemberDate()</p>
                </div>
            </div> *@

            <div class="header-center">
                <div class="tier-badge-row">
                    <span class="tier-badge">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="tier-star">
                            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                        </svg>
                        @affiliateInfo?.Tier.ToUpper()
                    </span>
                    <span class="active-status">
                        <span class="status-dot"></span>
                        <span>Active</span>
                    </span>
                </div>
                <p class="commission-info">
                    @GetCommissionRate()% commission per batch · @GetDiscountRate()% off for your referrals
                </p>
            </div>

            <div class="header-right">
               <p class="total-earnings-amount">$@((affiliateInfo?.CommissionEarned ?? 0).ToString("N2"))</p>
                <p class="total-earnings-label">LIFETIME COMMISSION EARNED</p>
            </div>
        </div>

        <!-- 2. TAB NAVIGATION (MUST BE HERE - OUTSIDE THE TAB IF BLOCKS) -->
        <div class="affiliate-tabs">
            <button class="tab-button @(activeAffiliateTab == "dashboard" ? "active" : "")"
                        @onclick='() => SelectAffiliateTab("dashboard")'>
                Dashboard
            </button>
            <button class="tab-button @(activeAffiliateTab == "partner-store" ? "active" : "")"
                    @onclick='() => activeAffiliateTab = "partner-store"'>
                Partner Store
            </button>
            <button class="tab-button @(activeAffiliateTab == "milestones" ? "active" : "")"
                    @onclick='() => activeAffiliateTab = "milestones"'>
                Milestones
            </button>
        </div>

        <!-- 3. NOW YOUR TAB CONTENT -->
        @if (activeAffiliateTab == "dashboard")
 {
     <div class="dashboard-content">
         @if (affiliateInfo != null)
         {
             <!-- 1. AFFILIATE LINK SECTION -->
             <div class="affiliate-link-section">
                 <p class="section-label">YOUR UNIQUE AFFILIATE LINK</p>
                 <div class="link-container">
                     <div class="link-display">@affiliateInfo.AffiliateLink</div>
                     <button class="copy-btn" @onclick="CopyLinkToClipboard">
                         <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                             <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                             <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
                         </svg>
                         Copy Link
                     </button>
                 </div>
                 @if (linkCopied)
                 {
                     <p class="success-message">✓ Link copied to clipboard!</p>
                 }

                 <!-- Share Buttons -->
                 <div class="share-buttons">
                     <span class="share-label">SHARE:</span>
                     <button class="share-icon-btn">
                         <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
