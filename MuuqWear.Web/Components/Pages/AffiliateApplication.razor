@page "/affiliate"
@using Microsoft.AspNetCore.Components.Authorization
@using MuuqWear.Application.Services.AffiliateService
@using MuuqWear.Model.AffiliateApplication
@inject IAffiliateService AffiliateService
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>Affiliate Program - MuuqWear</PageTitle>

<!-- HERO SECTION -->
<section class="mw-affiliate-hero">
    <div class="mw-affiliate-hero-content">
        <p class="mw-affiliate-eyebrow">The Ambassador Program</p>
        <h1 class="mw-affiliate-title">Exclusive. Limited. Rewarding.</h1>
        <p class="mw-affiliate-description">
            Muuqwear does not offer public discounts. Every discount comes exclusively through our trusted ambassadors.
            Join the inner circle of 500 members who share Muuqwear with their community and earn while you inspire.
        </p>

        <!--  AuthorizeView handles everything automatically -->
        <AuthorizeView>
            <Authorized>
                <!-- User is logged in - show apply button -->
                <button class="mw-affiliate-cta" @onclick="OpenApplicationModal">
                    Apply to Become an Ambassador
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </button>
            </Authorized>
            <NotAuthorized>
                <!-- User is NOT logged in - show login prompt -->
                <button class="mw-affiliate-cta" @onclick="RedirectToLogin">
                    Login to Apply
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </button>
            </NotAuthorized>
        </AuthorizeView>

        <p class="mw-affiliate-spots">
            @if (spotsRemaining > 0)
            {
                <span>Limited to 500 members worldwide. @spotsRemaining spots remaining.</span>
            }
            else
            {
                <span>All 500 spots are currently filled. Join the waitlist!</span>
            }
        </p>
    </div>
</section>
<section class="mw-affiliate-benefits">
    <div class="mw-benefits-container">
        <div class="mw-benefits-grid">

            <!-- Card 1: No Public Discounts -->
            <div class="mw-benefit-card">
                <div class="mw-benefit-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h3 class="mw-benefit-title">No Public Discounts</h3>
                <p class="mw-benefit-description">
                    Muuqwear never runs site-wide sales or public discount codes. All discounts flow through ambassadors.
                </p>
            </div>

            <!-- Card 2: Exclusive to 500 -->
            <div class="mw-benefit-card">
                <div class="mw-benefit-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                </div>
                <h3 class="mw-benefit-title">Exclusive to 500</h3>
                <p class="mw-benefit-description">
                    Limited membership ensures quality and authenticity. Annual evaluations maintain standards.
                </p>
            </div>

            <!-- Card 3: Tiered Rewards -->
            <div class="mw-benefit-card">
                <div class="mw-benefit-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
                        <polyline points="16 7 22 7 22 13"></polyline>
                    </svg>
                </div>
                <h3 class="mw-benefit-title">Tiered Rewards</h3>
                <p class="mw-benefit-description">
                    Bronze → Silver → Gold. Higher tiers unlock bigger rewards for you and your audience.
                </p>
            </div>

        </div>
    </div>
</section>




<section class="mw-how-it-works">
    <div class="mw-how-container">
        <!-- Header -->
        <div class="mw-how-header">
            <p class="mw-how-eyebrow">Step by Step</p>
            <h2 class="mw-how-title">How It Works</h2>
        </div>

        <!-- Steps -->
        <div class="mw-steps">

            <!-- Step 1: Apply -->
            <div class="mw-step">
                <div class="mw-step-number">01</div>
                <div class="mw-step-content">
                    <div class="mw-step-title-row">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        <h3>Apply</h3>
                    </div>
                    <p>Submit your application. If selected, you join an exclusive community of 500 members.</p>
                </div>
                <svg class="mw-step-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m9 18 6-6-6-6"></path>
                </svg>
            </div>

            <!-- Step 2: Share Your Link -->
            <div class="mw-step">
                <div class="mw-step-number">02</div>
                <div class="mw-step-content">
                    <div class="mw-step-title-row">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="18" cy="5" r="3"></circle>
                            <circle cx="6" cy="12" r="3"></circle>
                            <circle cx="18" cy="19" r="3"></circle>
                            <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
                            <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
                        </svg>
                        <h3>Share Your Link</h3>
                    </div>
                    <p>Get your unique affiliate link. Share it with your community. Every purchase through your link gives your audience an exclusive discount — the only discount Muuqwear offers.</p>
                </div>
                <svg class="mw-step-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m9 18 6-6-6-6"></path>
                </svg>
            </div>

            <!-- Step 3: Earn & Grow -->
            <div class="mw-step">
                <div class="mw-step-number">03</div>
                <div class="mw-step-content">
                    <div class="mw-step-title-row">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
                            <polyline points="16 7 22 7 22 13"></polyline>
                        </svg>
                        <h3>Earn & Grow</h3>
                    </div>
                    <p>Earn commission per 10 items sold. Unlock milestone bonuses. Level up tiers as you sell more. Every item sold counts as XP.</p>
                </div>
                <svg class="mw-step-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m9 18 6-6-6-6"></path>
                </svg>
            </div>

            <!-- Step 4: Get Rewarded -->
            <div class="mw-step">
                <div class="mw-step-number">04</div>
                <div class="mw-step-content">
                    <div class="mw-step-title-row">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="8" width="18" height="4" rx="1"></rect>
                            <path d="M12 8v13"></path>
                            <path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"></path>
                            <path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"></path>
                        </svg>
                        <h3>Get Rewarded</h3>
                    </div>
                    <p>Enjoy 25% off all personal purchases. Top ambassadors earn event tickets, travel packages, and exclusive experiences.</p>
                </div>
            </div>

        </div>
    </div>
</section>

