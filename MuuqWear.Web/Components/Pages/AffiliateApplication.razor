        </div>

        <!-- Commission Table Section -->
        <div class="mw-commission-table-section">
            <h3 class="mw-commission-subtitle">Commission Per 10 Items Sold</h3>

            <div class="mw-table-wrapper">
                <table class="mw-commission-table">
                    <thead>
                        <tr>
                            <th>Tier</th>
                            <th>Rate</th>
                            <th>Example (10 items / $5,500)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="mw-tier-cell">Bronze</td>
                            <td>2.5%</td>
                            <td class="mw-amount-cell">$137.50</td>
                        </tr>
                        <tr class="mw-table-alt">
                            <td class="mw-tier-cell">Silver</td>
                            <td>5%</td>
                            <td class="mw-amount-cell">$275.00</td>
                        </tr>
                        <tr>
                            <td class="mw-tier-cell">Gold</td>
                            <td>10%</td>
                            <td class="mw-amount-cell">$550.00</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="mw-commission-notes">
                <p>
                    <span class="mw-bullet">•</span>
                    Commission is paid in batches of 10 items sold
                </p>
                <p>
                    <span class="mw-bullet">•</span>
                    When you reach another multiple of 10, you receive commission on those last 10 items
                </p>
                <p>
                    <span class="mw-bullet">•</span>
                    Each item sold counts toward your XP regardless of price
                </p>
            </div>
        </div>

