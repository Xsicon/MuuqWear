<!-- APPLICATION MODAL -->
@if (showModal)
{
    <div class="mw-modal-overlay" @onclick="CloseModal">
        <div class="mw-modal-content" @onclick:stopPropagation="true">
            <!-- Header -->
            <div class="mw-modal-header">
                <h2 class="mw-modal-title">Affiliate Application</h2>
                <button type="button" class="mw-modal-close" @onclick="CloseModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6 6 18"></path>
                        <path d="m6 6 12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- Form Body -->
            <div class="mw-modal-body">
                @if (!submitted)
                {
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="mw-form-error">
                            @errorMessage
                        </div>
                    }

                    <p class="mw-form-intro">
                        Join our exclusive 500-member affiliate program. Gold affiliates receive all-expenses-paid trips to Muuqsimo.
                    </p>

                    <!-- Full Name -->
                    <div class="mw-form-field">
                        <label>Full Name</label>
                        <input type="text" @bind="model.FullName" placeholder="Enter your full name" />
                    </div>

                    <!-- Email -->
                    <div class="mw-form-field">
                        <label>Email Address</label>
                        <input type="email" @bind="model.Email" placeholder="your@email.com" />
                    </div>

                    <!-- Social Media -->
                    <div class="mw-form-field">
                        <label>Social Media Handles</label>
                        <div class="mw-social-handles">
                            @for (int i = 0; i < model.SocialHandles.Count; i++)
                            {
                                var index = i;
                                var handle = model.SocialHandles[index];

                                <div class="mw-social-row">
                                    @if (handle.Platform == "Instagram")
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                                        </svg>
                                    }
                                    else if (handle.Platform == "TikTok")
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                                        </svg>
                                    }
                                    else if (handle.Platform == "YouTube")
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path>
                                            <path d="m10 15 5-3-5-3z"></path>
                                        </svg>
                                    }

                                    <input type="text" @bind="model.SocialHandles[index].Handle" placeholder="@@@(handle.Platform.ToLower())" />
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Audience Size -->
                    <div class="mw-form-field">
                        <label>Audience Size</label>
                        <input type="number" @bind="model.AudienceSize" placeholder="Total followers across all platforms" min="100" />
                    </div>

                    <!-- Content Niche -->
                    <div class="mw-form-field">
                        <label>Content Niche (Fashion, Lifestyle, Streetwear, etc.)</label>
                        <input type="text" @bind="model.ContentNiche" placeholder="e.g., Fashion & Lifestyle" />
                    </div>

                    <!-- Portfolio URL -->
                    <div class="mw-form-field">
                        <label>Portfolio / Website URL</label>
                        <input type="url" @bind="model.PortfolioUrl" placeholder="https://..." />
                    </div>

                    <!-- Why Question -->
                    <div class="mw-form-field">
                        <label>Why do you want to represent Muuqwear?</label>
                        <textarea rows="4" @bind="model.WhyMuuqwear" placeholder="Tell us why you'd be a great fit..."></textarea>
                    </div>

                    <!-- Sample Content Upload (Placeholder) -->
                    <div class="mw-form-field">
                        <label>Sample Content (max 5 files)</label>
                        <div class="mw-file-upload-placeholder">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="17 8 12 3 7 8"></polyline>
                                <line x1="12" x2="12" y1="3" y2="15"></line>
                            </svg>
                            <span>Click to upload images or videos</span>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="button" class="mw-submit-btn" @onclick="HandleSubmit" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <span>Submit Application</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14"></path>
                                <path d="m12 5 7 7-7 7"></path>
                            </svg>
                        }
                    </button>

                    <p class="mw-form-footer">
                        Review period: 7-14 business days. Limited to 500 active ambassadors.
                    </p>
                }
                else
                {
                    <!-- Success State -->
                    <div class="mw-success-state">
                        <div class="mw-success-icon">✓</div>
                        <h3>Application Submitted!</h3>
                        <p>Thank you for applying. We'll review your application and get back to you within 7-14 business days.</p>
                        <button type="button" class="mw-close-btn" @onclick="CloseModal">
                            Close
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}


@code {
    private bool showModal = false;
    private bool submitted = false;
    private bool isSubmitting = false;
    private string errorMessage = "";
    private string showAlertMessage = "";
    private int spotsRemaining = 0;
    private AffiliateStatusModel? affiliateStatus = new AffiliateStatusModel();
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    // FAQ State
    private int? openFaqIndex = null;

    private List<FaqItem> faqs = new()
    {
        new FaqItem
        {
            Question = "How do I get my affiliate link?",
            Answer = "Once approved, your unique link appears in your Ambassador Dashboard. Copy and share it anywhere."
        },
        new FaqItem
        {
            Question = "Why doesn't Muuqwear have public discounts?",
            Answer = "We believe in maintaining brand value and rewarding our community members who authentically share Muuqwear. All discounts come through trusted ambassadors, not mass sales."
        },
        new FaqItem
        {
            Question = "How do my followers get their discount?",
            Answer = "When someone clicks your affiliate link, the discount is automatically pre-applied to their cart. They see a banner confirming they're shopping with you and enjoying your exclusive discount."
        },
        new FaqItem
        {
            Question = "How do I level up to the next tier?",
            Answer = "Every item sold through your link counts as 1 XP. Bronze unlocks at 50 items, Silver at 150 items, and Gold at 500 items. Track your progress in real-time on your dashboard."
        },
        new FaqItem
        {
            Question = "When do I get paid?",
            Answer = "Commission is earned in batches of 10 items sold. Once you reach a multiple of 10, that commission is added to your balance. You can request payout once you reach a minimum of $50."
        },
        new FaqItem
        {
            Question = "Can I use my personal discount and affiliate link together?",
            Answer = "Your 25% personal discount is for your own purchases only and cannot be combined with your affiliate link. Your affiliate link provides discounts for your audience."
        },
        new FaqItem
        {
            Question = "What happens if I stop selling?",
            Answer = "We conduct annual evaluations. Inactive ambassadors may be moved to a waitlist to make room for active members. Stay engaged to maintain your status."
        },
        new FaqItem
        {
            Question = "Is the program really limited to 500 members?",
            Answer = "Yes. We maintain an exclusive community of 500 active ambassadors worldwide. When we reach capacity, new applicants are added to a waitlist."
        },
        new FaqItem
        {
            Question = "Can I share my link on paid ads?",
            Answer = "Organic sharing is encouraged. Paid advertising requires prior approval. Contact us through your dashboard to discuss paid promotion opportunities."
        },
        new FaqItem
        {
            Question = "How do I get free tickets to Muuqsimo?",
            Answer = "Silver tier ambassadors receive complimentary tickets to our annual Muuqsimo gala. Gold tier members receive an all-expenses-paid trip including flights, hotel, and VIP access."
        }
    };

    public class FaqItem
    {
        public string Question { get; set; } = string.Empty;
        public string Answer { get; set; } = string.Empty;
    }
    private void ToggleFaq(int index)
    {
        if (openFaqIndex == index)
        {
            // Close if already open
            openFaqIndex = null;
        }
        else
        {
            // Open the clicked one (closes any other)
            openFaqIndex = index;
        }
    }

    private SubmitAffiliateApplicationModel model = new()
    {
        SocialHandles = new List<SocialHandleModel>
        {
            new() { Platform = "Instagram" },
            new() { Platform = "TikTok" },
            new() { Platform = "YouTube" }
        }
    };

    protected override async Task OnInitializedAsync()
    {
        // Only load status for authenticated users
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (authState.User.Identity?.IsAuthenticated ?? false)
            {
                await LoadAffiliateStatus();
            }
        }
        await LoadSpotsRemaining();
    }



    private void RedirectToLogin()
    {
        // Save current URL so user returns here after login
        NavigationManager.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/affiliate")}", true);
    }

    private async Task LoadSpotsRemaining()
    {
        var result = await AffiliateService.GetSpotsRemaining();
        if (result.Success)
        {
            spotsRemaining = result.Data;
        }
    }

    private async Task LoadAffiliateStatus()
    {
        try
        {
            var result = await AffiliateService.GetStatus();
            if (result.Success && result.Data != null)
            {
                affiliateStatus = result.Data;

                // Show prompt if user hasn't applied yet
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading affiliate status: {ex.Message}");
        }

    }

    private void OpenApplicationModal()
    {
        // Check if user can apply
        if (affiliateStatus == null)
        {
            showAlertMessage = "Please wait, loading your status...";
            return;
        }

        if (affiliateStatus.ApplicationStatus == "pending")
        {
            showAlertMessage = "Your application is currently under review. We'll notify you within 7-14 business days.";
            return;
        }

        if (affiliateStatus.ApplicationStatus == "approved")
        {
            showAlertMessage = "You're already an approved affiliate! Check your profile to access your dashboard.";
            return;
        }

        if (affiliateStatus.ApplicationStatus == "rejected")
        {
            showAlertMessage = "Your previous application was not approved. You may reapply after 30 days.";
            return;
        }

        if (affiliateStatus.ApplicationStatus == "waitlisted")
        {
            showAlertMessage = "You're on the waitlist. We'll notify you when a spot opens up.";
            return;
        }

        // Only open modal if status is "not_applied"
        if (affiliateStatus.ApplicationStatus == "not_applied")
        {
            showModal = true;
            submitted = false;
            errorMessage = "";

            model = new SubmitAffiliateApplicationModel
            {
                SocialHandles = new List<SocialHandleModel>
            {
                new() { Platform = "Instagram" },
                new() { Platform = "TikTok" },
                new() { Platform = "YouTube" }
            }
            };
        }
    }

    private void CloseModal()
    {
        showModal = false;
        submitted = false;
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";
        isSubmitting = true;

        try
        {
            // Validation
            if (string.IsNullOrWhiteSpace(model.FullName))
            {
                errorMessage = "Full name is required";
                return;
            }

            if (string.IsNullOrWhiteSpace(model.Email))
            {
                errorMessage = "Email is required";
                return;
            }

            var validHandles = model.SocialHandles
            .Where(h => !string.IsNullOrWhiteSpace(h.Handle))
            .ToList();

            if (!validHandles.Any())
            {
                errorMessage = "Please add at least one social media handle";
                return;
            }

            if (model.AudienceSize < 100)
            {
                errorMessage = "Minimum audience size is 100 followers";
                return;
            }

            if (string.IsNullOrWhiteSpace(model.ContentNiche))
            {
                errorMessage = "Content niche is required";
                return;
            }

            var request = new SubmitAffiliateApplicationModel
            {
                FullName = model.FullName,
                Email = model.Email,
                SocialHandles = validHandles,
                AudienceSize = model.AudienceSize,
                ContentNiche = model.ContentNiche,
                PortfolioUrl = model.PortfolioUrl,
                WhyMuuqwear = model.WhyMuuqwear,
                SampleFiles = new List<string>
                ()
            };

            var result = await AffiliateService.SubmitApplication(request);

            if (result.Success)
            {
                submitted = true;
                await LoadSpotsRemaining(); // Refresh spots count
            }
            else
            {
                errorMessage = result.Message ?? "Failed to submit application";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
    private void CloseAlert()
    {
        showAlertMessage = "";
    }


}
