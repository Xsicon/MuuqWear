@page "/forgot-password"
@layout Layout.AuthLayoutComponent.AuthLayoutComponent
@rendermode InteractiveServer
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Application.Shared
@using MuuqWear.Model.Authentication
@inject IAuthService IAuthService
@inject NavigationManager NavigationManager

<PageTitle>Forgot Password</PageTitle>

<section class="mw-auth">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-6 col-lg-4 mt-5">
                <div class="mw-auth-card text-center">
                    <a href="/">
                        <img href="/" src="/images/muuqwearlogo.png" class="mw-auth-logo mb-3" />
                    </a>
                    <h2 class="mw-auth-title">Forgot Password</h2>
                    <p class="mw-auth-subtitle mb-4">
                        Enter your email and we'll send you
                        a link to reset your password.
                    </p>

                    @if (!emailSent)
                    {
                        <!-- FORM -->
                        <div class="mb-3">
                            <input class="form-control mw-input"
                                   placeholder="Enter your email"
                                   @bind="email"
                                   @bind:event="oninput" />
                        </div>

                        <button type="button"
                                class="mw-btn-primary w-100"
                                @onclick="HandleForgotPassword"
                                disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="mw-btn-spinner"></span>
                                <span>Sending...</span>
                            }
                            else
                            {
                                <span>Send Reset Link</span>
                            }
                        </button>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="@errrorMessageCssClass">
                                <span>@errorMessage</span>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- SUCCESS STATE -->
                        <div class="mw-reset-success">
                            <div class="mw-reset-success__icon">✉</div>
                            <h6 class="mt-3 fw-bold">Check your email</h6>
                            <p class="mw-auth-subtitle">
                                We sent a password reset link to
                                <strong>@email</strong>
                            </p>
                            <p class="small text-muted mt-2">
                                Didn't receive it?
                                <button class="mw-link-btn"
                                        @onclick="ResendEmail">
                                    Click to resend
                                </button>
                            </p>
                        </div>
                    }

                    <!-- BACK TO LOGIN -->
                    <p class="text-center mt-4 small">
                        Remember your password?
                        <a href="/login" class="mw-link">Sign in</a>
                    </p>

                </div>
            </div>
        </div>
    </div>
</section>

@code {

    private string email = string.Empty;
    private bool isSubmitting = false;
    private bool emailSent = false;
    private string errorMessage = string.Empty;
    private string errrorMessageCssClass = "";

    private async Task HandleForgotPassword()
    {
        // validate email
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Please enter your email";
            errrorMessageCssClass = "text-danger";
            return;
        }

        if (!MuuqWearUtils.IsValidEmail(email))
        {
            errorMessage = "Please enter a valid email address";
            errrorMessageCssClass = "text-danger";
            return;
        }


        isSubmitting = true;
        errorMessage = string.Empty;
        StateHasChanged();

        var result = await IAuthService.SendPasswordReset(
            new ForgotPasswordModel { Email = email });

        if (result.Success)
        {
            // show success state 
            emailSent = true;
        }
        else
        {
            errorMessage = result.Message;
        }

        isSubmitting = false;
    }

    private async Task ResendEmail()
    {
        // reset to form state
        emailSent = false;
        errorMessage = string.Empty;
        StateHasChanged();

        // resend email
        await HandleForgotPassword();
    }
}