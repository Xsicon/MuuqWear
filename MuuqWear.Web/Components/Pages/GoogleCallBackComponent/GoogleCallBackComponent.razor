@page "/auth/google-callback"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IAuthService IAuthService
@inject AuthStateService AuthStateService
@inject CustomAuthenticationStateProvider CustomAuthStateProvider
@inject CartStateService CartStateService
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Application.Services.CartService
@using MuuqWear.Application.Shared
@using MuuqWear.Model.Authentication


<PageTitle>Signing in with Google...</PageTitle>

<div class="container py-5 text-center">
    @if (isVerifying)
    {
        <p>Signing in with Google...</p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="text-danger">@errorMessage</p>
        <a href="/login" class="mw-btn-primary mt-3">
            Back to Login
        </a>
    }
</div>

@code {

    private bool isVerifying = true;
    private string errorMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // read URL fragment via JS
            // Google OAuth returns tokens in URL fragment
            // e.g. #access_token=xxx&refresh_token=yyy&provider_token=zzz
            var fragment = await JS.InvokeAsync<string>(
                "eval", "window.location.hash");

            if (string.IsNullOrEmpty(fragment))
            {
                errorMessage = "Invalid Google callback. Please try again.";
                isVerifying = false;
                StateHasChanged();
                return;
            }

            // parse fragment into key-value pairs
            var parameters = fragment
                .TrimStart('#')
                .Split('&')
                .Select(p => p.Split('='))
                .Where(p => p.Length == 2)
                .ToDictionary(
                    p => p[0],
                    p => Uri.UnescapeDataString(p[1]));

            // get access token
            if (!parameters.TryGetValue("access_token", out var accessToken)
                || string.IsNullOrEmpty(accessToken))
            {
                errorMessage = "Google sign in failed. Token missing.";
                isVerifying = false;
                StateHasChanged();
                return;
            }

            // get refresh token
            parameters.TryGetValue("refresh_token", out var refreshToken);

            // verify token with backend
            // reuse same VerifyMagicLink method
            // both use access_token + refresh_token 
            var result = await IAuthService.VerifyMagicLink(
                new MagicLinkVerifyModel
                {
                    AccessToken = accessToken,
                    RefreshToken = refreshToken ?? ""
                });

            if (result.Success && result.Data != null)
            {
                // navigate to set cookie
                await AuthNavigationHelper.PrepareAndNavigateAsync(
                    result.Data,
                    NavigationManager,
                    CustomAuthStateProvider,
                    JS,
                    "/profile");
            }
            else
            {
                errorMessage = result.Message ?? "Google sign in failed.";
                isVerifying = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Something went wrong. Please try again.";
            isVerifying = false;
            StateHasChanged();
            Console.WriteLine(ex.Message);
        }
    }
}