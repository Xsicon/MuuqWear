    private bool isSearchOpen = false;

    void OpenSearch()
    {
        isSearchOpen = true;
        shouldFocusInput = true;
    }
    private bool isCartOpen = false;
    void CloseSearch()
    {
        isSearchOpen = false;
        ClearSearch(); // reset search when panel closes
    }

    void OpenCart()
    {
        isCartOpen = true;
        // await JS.InvokeVoidAsync("disableScroll");
    }

    void CloseCart()
    {
        isCartOpen = false;
        // await JS.InvokeVoidAsync("enableScroll");
    }

