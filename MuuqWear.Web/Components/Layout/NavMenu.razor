    // qty decrease
    private async Task DecreaseQty(CartItemModel item)
    {
        if (item.Quantity <= 1) return;
        await CartStateService.UpdateQuantity(
            item.Id, item.Quantity - 1);
    }

    // qty increase
    private async Task IncreaseQty(CartItemModel item)
    {
        await CartStateService.UpdateQuantity(
            item.Id, item.Quantity + 1);
    }

    // remove item
    private async Task RemoveItem(Guid cartItemId)
    {
        await CartStateService.RemoveItem(cartItemId);
    }

