@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div>

    <header class="mw-header" role="banner">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between py-3">

                <!-- LOGO -->
                <a href="/" class="mw-logo d-flex align-items-center text-decoration-none">
                    <img src="/images/muuqwearlogo.png"
                         alt="MuuqWear logo"
                         class="mw-logo__img img-fluid" />
                    <span class="mw-logo__text text-uppercase fw-bolder ms-2 d-none d-md-flex">
                        MuuqWear
                    </span>
                </a>

                <!-- RIGHT SIDE -->
                <div class="d-flex align-items-center gap-3">

                    <!-- DESKTOP NAV -->
                    <nav class="mw-nav d-none d-md-flex gap-4">
                        <NavLink class="mw-nav__link" href="/" Match="NavLinkMatch.All">Home</NavLink>
                        <NavLink class="mw-nav__link" href="/shop/apparel">Apparel</NavLink>
                        <NavLink class="mw-nav__link" href="/shop/accessories">Accessories</NavLink>
                        <NavLink class="mw-nav__link" href="/community">Community</NavLink>
                        <NavLink class="mw-nav__link" href="/journal">Journal</NavLink>
                    </nav>

                    <!-- ICONS -->
                    <div class="mw-header__icons d-flex align-items-center gap-2">

                        <button class="mw-icon-btn" aria-label="Search" @onclick="OpenSearch">
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                                <circle cx="10" cy="10" r="7" stroke="#1E2B48" stroke-width="2" />
                                <path d="M15 15L20 20" stroke="#1E2B48" stroke-width="2" />
                            </svg>
                        </button>

                        <button class="mw-icon-btn" aria-label="Cart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                                <path d="M3 6h18"></path>
                                <path d="M16 10a4 4 0 0 1-8 0"></path>
                            </svg>
                        </button>
                        <NavLink href="/profile" aria-label="Profile">
                            <button class="mw-icon-btn" aria-label="Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </button>
                            </NavLink>

                            <button class="mw-icon-btn" aria-label="Location">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                            </button>

                    </div>

                    <!-- HAMBURGER -->
                    <button class="mw-icon-btn mw-hamburger d-flex d-md-none"
                            aria-label="Toggle navigation"
                            aria-expanded="@isMenuOpen"
                            @onclick="ToggleMenu">
                        @if (isMenuOpen)
                        {
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                                <path d="M5 5L17 17" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                                <path d="M17 5L5 17" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                            </svg>
                        }
                        else
                        {
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                                <path d="M3 6H19" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                                <path d="M3 11H19" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                                <path d="M3 16H19" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                            </svg>
                        }
                    </button>

                </div>
            </div>
        </div>
    </header>

    <!-- Search Panel-->

    <div class="mw-search-overlay @(isSearchOpen ? "open" : "")"
         @onclick="CloseSearch">

        <!-- PANEL -->
        <div class="mw-search-panel" @onclick:stopPropagation="true">

            <!-- CLOSE BUTTON -->
            <button class="mw-search-close" @onclick="CloseSearch">
                ✕
            </button>

            <!-- CONTENT -->
            <div class="mw-search-content container">

                <!-- INPUT -->
                <div class="row">
                    <div class="col-12">
                        <input class="mw-search-input" @ref="searchInputRef"
                               placeholder="Search for 'Hoodie', 'Sapphire'..." />
                    </div>
                </div>

                <!-- BODY -->
                <div class="row mt-4 justify-content-center text-center">

                    <!-- LEFT: TAGS -->
                    <div class="col-12 col-md-6">
                        <div class="mw-search-tags justify-content-center">
                            <span>New Arrivals</span>
                            <span>Hoodies</span>
                            <span>Accessories</span>
                            <span>Sale</span>
                        </div>
                    </div>

                    <!-- RIGHT: POPULAR -->
                    <div class="row mt-5">
                        <div class="col-12 col-md-4 ms-md-auto text-md-end text-start">
                            <p class="mw-search-label">POPULAR SEARCHES</p>

                            <ul class="mw-search-list">
                                <li>Sapphire Hoodie</li>
                                <li>Cargo Pants</li>
                                <li>Veil Crossbody</li>
                                <li>Tech Jacket</li>
                            </ul>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>



    <!-- OVERLAY — sibling to header, both inside the wrapper div -->
    <div class="mw-mobile-nav d-md-none @(isMenuOpen ? "mw-mobile-nav--open" : "")"
         @onclick="HandleOverlayClick">
        <div class="mw-mobile-nav__panel" @onclick:stopPropagation="true">

            <div class="mw-mobile-nav__header text-uppercase fw-bolder">
                <span>Menu</span>
                <button class="mw-mobile-nav__close" @onclick="CloseMenu" aria-label="Close menu">
                    <svg width="18" height="18" viewBox="0 0 22 22" fill="none">
                        <path d="M5 5L17 17" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                        <path d="M17 5L5 17" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <nav class="mw-mobile-nav__body text-uppercase">
                <NavLink class="mw-mobile-nav__link p-2 border-bottom d-flex justify-content-between align-items-center" href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">
                    <span>Home</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
                </NavLink>
                <NavLink class="mw-mobile-nav__link p-2 border-bottom d-flex justify-content-between align-items-center" href="/shop/apparel" @onclick="CloseMenu">
                    <span>Apparel</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
                </NavLink>
                <NavLink class="mw-mobile-nav__link p-2 border-bottom d-flex justify-content-between align-items-center" href="/shop/accessories" @onclick="CloseMenu">
                    <span>Accessories</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
                </NavLink>
                <NavLink class="mw-mobile-nav__link p-2 border-bottom d-flex justify-content-between align-items-center" href="/community" @onclick="CloseMenu">
                    <span>Community</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
                </NavLink>
                <NavLink class="mw-mobile-nav__link p-2 border-bottom d-flex justify-content-between align-items-center" href="/journal" @onclick="CloseMenu">
                    <span>Journal</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2B48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
                </NavLink>
            </nav>

        </div>
    </div>

</div>


@code {

    private ElementReference searchInputRef;
    private bool isMenuOpen = false;
    private bool shouldFocusInput = false;

    async Task ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;

        if (isMenuOpen)
            await JS.InvokeVoidAsync("disableScroll");
        else
            await JS.InvokeVoidAsync("enableScroll");
    }

    async Task CloseMenu()
    {
        isMenuOpen = false;
        await JS.InvokeVoidAsync("enableScroll");
    }
    private void HandleOverlayClick() => isMenuOpen = false;
    private bool isSearchOpen = false;

    void OpenSearch()
    {
        isSearchOpen = true;
        shouldFocusInput = true;
    }
    void CloseSearch() => isSearchOpen = false;
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(() =>
        {
            isMenuOpen = false;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldFocusInput)
        {
            shouldFocusInput = false;

            try
            {
                await JS.InvokeVoidAsync("focusElement", searchInputRef);
            }
            catch
            {
                // prevents crash if component unmounted
            }
        }
    }
}