@implements IDisposable
@inject AuthStateService AuthStateService
@using MuuqWear.Application.Services.AuthService
@using MuuqWear.Web.Components.Shared
@inherits LayoutComponentBase

<div id="admin-auth-overlay" style="position:fixed;top:0;left:0;width:100%;height:100%;background:white;z-index:9999;"></div>

<div class="mw-admin">
    <aside class="mw-admin-sidebar d-none d-md-flex">
        <AdminNavMenu />
    </aside>
    <div class="mw-admin-main">
        <div class="mw-admin-topbar">
            <!-- your existing topbar -->
        </div>
        <div class="mw-admin-content container-fluid">
            @Body
        </div>
    </div>
</div>

<AdminAuthCheck />

@code {
    private bool isMenuOpen = false;
    void ToggleMenu() { isMenuOpen = !isMenuOpen; StateHasChanged(); }
    void CloseMenu() { isMenuOpen = false; StateHasChanged(); }
    void HandleOverlayClick() { isMenuOpen = false; StateHasChanged(); }

    public void Dispose() { }
}