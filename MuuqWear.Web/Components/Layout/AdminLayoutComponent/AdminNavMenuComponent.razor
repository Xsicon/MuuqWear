    <NavLink href="/admin/settings"
             class="an-nav__item"
             onclick="window.adminSidebar.close()">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
            <circle cx="12" cy="12" r="3"></circle>
        </svg>
        <span class="an-nav__label">Settings</span>
    </NavLink>

    <NavLink href="/admin/jobs"
             class="an-nav__item"
             onclick="window.adminSidebar.close()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase">
            <path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
            <rect width="20" height="14" x="2" y="6" rx="2">

            </rect>
        </svg>
        <span class="an-nav__label">Careers</span>
    </NavLink>

</nav>

@code {
    [Parameter] public EventCallback OnLinkClicked { get; set; }

    private string userName = string.Empty;
    private string userInitials = "AD";
    private int openTickets = 0;
    private AdminBadgeCountsModel? counts;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var user = authState.User;

        userName = user.FindFirst("FullName")?.Value
                   ?? user.FindFirst("name")?.Value
                   ?? "Admin";

        //  generate initials from name
        var parts = userName.Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        userInitials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
        var result = await BadgeService.GetCounts();
        if (result.Success && result.Data != null)
        {
            counts = result.Data;
        }
    }
}
