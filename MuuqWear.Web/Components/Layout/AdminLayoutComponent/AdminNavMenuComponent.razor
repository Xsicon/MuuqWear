@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using MuuqWear.Application.Services.AdminBadgeService
@using MuuqWear.Model.AdminBadgeCount
@inject AuthenticationStateProvider AuthStateProvider
@inject IAdminBadgeService BadgeService

<!-- ─── BRAND ──────────────────────────────────────────── -->
<div class="an-brand">
    <p class="an-brand__name">Muuqwear</p>
    <p class="an-brand__sub">Internal Dashboard</p>
</div>

<!-- ─── USER ───────────────────────────────────────────── -->
<div class="an-user">
    <div class="an-user__avatar">@userInitials</div>
    <div>
        <p class="an-user__name">@userName</p>
        <p class="an-user__role">Admin</p>
    </div>
</div>

<!-- ─── NAV ────────────────────────────────────────────── -->
<nav class="an-nav">

