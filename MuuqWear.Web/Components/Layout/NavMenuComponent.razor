    protected override async Task OnInitializedAsync()
    {
        await SyncAuthStateAsync();
    }

    private async Task SyncAuthStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        isUserAuthenticated = isAuthenticated;

        if (isAuthenticated)
        {
            var role = authState.User.FindFirst(ClaimTypes.Role)?.Value;
            isAdmin = role?.ToLower() == "admin";

            if (!isAdmin)
            {
                userName = authState.User.FindFirst(ClaimTypes.Name)?.Value
                    ?? authState.User.Identity?.Name;
                userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value;
            }
        }
        else
        {
            isAdmin = false;
            userName = null;
            userEmail = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        //  check on every render if session expired
        if (AuthSession.IsSessionExpired)
        {

            AuthSession.Reset(); // ← reset BEFORE redirect to prevent loop
            await JS.InvokeVoidAsync("eval",
                "window.location.href='/auth/clear?expired=true'");
            return;
        }
        if (firstRender && !_cartInitialized)
        {
            _cartInitialized = true;

            var authState = await AuthStateProvider
                .GetAuthenticationStateAsync();

            var isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            var userId = authState.User.FindFirst("UserId")?.Value;
            isUserAuthenticated = isAuthenticated;
            if (isAuthenticated)
            {
                var role = authState.User.FindFirst(ClaimTypes.Role)?.Value;
                isAdmin = role?.ToLower() == "admin";
                if (!isAdmin)
                {
                    userName = authState.User.FindFirst(ClaimTypes.Name)?.Value
                        ?? authState.User.Identity?.Name;
                    userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value;
                }
            }
            else
            {
                isAdmin = false;
                userName = null;
                userEmail = null;
            }

            if (isAuthenticated)
            {
                var cookieJson = await JS.InvokeAsync<string?>("getCartCookie");
                var hadGuestCart = !string.IsNullOrEmpty(cookieJson);

                if (hadGuestCart)
                {
                    await CartStateService.LoadGuestCartFromCookie();

                    // merge into DB
                    // MergeGuestCartAsync internally loads DB cart after merge
                    await CartStateService.MergeGuestCartAsync();
                }
                else
                {
                    // no guest items → just load DB cart
                    await CartStateService.InitializeAsync(isAuthenticated, userId);
                }
            }
            else
            {
                // guest → load from cookie
                await CartStateService.InitializeAsync(isAuthenticated, userId);
            }

            StateHasChanged();
        }

        if (shouldFocusInput)
        {
            shouldFocusInput = false;
            try
            {
                await JS.InvokeVoidAsync("focusElement", searchInputRef);
            }
            catch { }
        }
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        // update search query as user types
        searchQuery = e.Value?.ToString() ?? string.Empty;
        activeSearchCategoryId = null;

        // if cleared → reset state
        if (string.IsNullOrEmpty(searchQuery))
        {
            ClearSearch();
            return;
        }

        // cancel previous debounce timer
        // user is still typing
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();

        try
        {
            // wait 300ms before searching
            // if user types again → Task.Delay cancelled
            await Task.Delay(300, _searchCts.Token);

            // 300ms passed → user stopped typing
            // → search now
            await PerformSearch();
        }
        catch (TaskCanceledException)
        {
            // user typed again → debounce cancelled
            // do nothing → new timer started
        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        // only react to Enter key
        if (e.Key == "Enter" && !string.IsNullOrEmpty(searchQuery))
        {
            // cancel debounce → search immediately
            _searchCts?.Cancel();
            await PerformSearch();
        }

        // close on Escape key
        if (e.Key == "Escape")
        {
            CloseSearch();
        }
    }

    private void ClearSearch()
    {
        // reset all search state
        searchQuery = string.Empty;
        activeSearchCategoryId = null;
        searchResults = new();
        hasSearched = false;
        isSearching = false;
        _searchCts?.Cancel();
        StateHasChanged();
    }

    private async Task PerformSearch()
    {
        // validate — need text or a category filter
        if (string.IsNullOrWhiteSpace(searchQuery) && !activeSearchCategoryId.HasValue)
            return;

        try
        {
            // show loading state
            isSearching = true;
            hasSearched = true;
            StateHasChanged();

            var filter = new ProductFilterModel
            {
                Page = 1,
                PageSize = 4,
                CategoryId = activeSearchCategoryId,
                Search = activeSearchCategoryId.HasValue
                    ? null
                    : searchQuery.Trim()
            };

            var result = await ProductService.GetAll(filter);

            if (result.Success && result.Data != null)
            {
                searchResults = result.Data.Data;
            }
            else
            {
                // API failed → empty results
                searchResults = new();
            }
        }
        catch (Exception ex)
        {
            // network error etc → empty results
            searchResults = new();
            Console.WriteLine($"Search error: {ex.Message}");
        }
        finally
        {
            // always hide loading
            // even if error occurs
            isSearching = false;
            StateHasChanged();
        }
    }

    private async Task SearchByTag(string tag)
    {
        searchQuery = tag;
        activeSearchCategoryId = null;
        hasSearched = true;

        // cancel any pending debounce
        _searchCts?.Cancel();

        // search immediately
        await PerformSearch();
    }

    private async Task SearchByCategory(CategoryModel category)
    {
        searchQuery = category.Name ?? string.Empty;
        activeSearchCategoryId = category.Id;
        hasSearched = true;

        _searchCts?.Cancel();
        await PerformSearch();
    }

    private string GetViewAllHref()
    {
        if (activeSearchCategoryId.HasValue)
            return $"/shop/apparel?categoryId={activeSearchCategoryId.Value}";

        return $"/shop/apparel?search={Uri.EscapeDataString(searchQuery)}";
    }

    private string SearchInputPlaceholder
    {
        get
        {
            var hints = new List<string>();

            if (searchCategories.Count > 0 && !string.IsNullOrWhiteSpace(searchCategories[0].Name))
                hints.Add(searchCategories[0].Name!);

            if (popularSearches.Count > 0)
            {
                var productHint = popularSearches[0].Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
                if (!string.IsNullOrWhiteSpace(productHint) &&
                    !hints.Contains(productHint, StringComparer.OrdinalIgnoreCase))
                {
                    hints.Add(productHint);
                }
            }

            if (hints.Count == 0)
                return "Search products...";

            return $"Search for '{string.Join("', '", hints.Take(2))}'...";
        }
    }

    private async Task LoadSearchSuggestions()
    {
        isLoadingSearchSuggestions = true;
        StateHasChanged();

        try
        {
            var categoriesTask = CategoryService.GetAll();
            var homeTask = ProductService.GetHomeProducts();

            await Task.WhenAll(categoriesTask, homeTask);

            var categoriesResult = await categoriesTask;
            var homeResult = await homeTask;

            if (categoriesResult.Success && categoriesResult.Data != null)
            {
                searchCategories = categoriesResult.Data
                    .Where(c => !string.IsNullOrWhiteSpace(c.Name))
                    .Take(4)
                    .ToList();
            }

            if (homeResult.Success && homeResult.Data != null)
            {
                popularSearches = homeResult.Data.BestSellers
                    .Concat(homeResult.Data.Featured)
                    .Concat(homeResult.Data.NewArrivals)
                    .Where(p => !string.IsNullOrWhiteSpace(p.Name))
                    .Select(p => p.Name!)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Take(4)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search suggestions error: {ex.Message}");
        }
        finally
        {
            isLoadingSearchSuggestions = false;
            searchSuggestionsLoaded = true;
            StateHasChanged();
        }
    }
